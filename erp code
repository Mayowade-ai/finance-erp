// ── ENTRY POINT ─────────────────────────────────────────────────
// IMPORTANT: Deploy as Web App → Execute as: Me → Who has access: Anyone
// After ANY code change: Deploy → Manage Deployments → Edit → New Version → Deploy
function doGet(e) {
  // Defensive guard: e can be undefined when run from script editor
  e = e || {};
  e.parameter = e.parameter || {};

  const token  = e.parameter.token  || '';
  const action = e.parameter.action || '';

  // No token + no action = direct browser visit -> SERVE THE DASHBOARD
  if (!token && !action) {
    try {
      return HtmlService
        .createHtmlOutputFromFile('Dashboard')
        .setTitle('RHV Hospital ERP Dashboard')
        .addMetaTag('viewport', 'width=device-width, initial-scale=1')
        .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
    } catch (htmlErr) {
      // Dashboard HTML file not found in this project
      return HtmlService.createHtmlOutput(
        '<div style="font-family:sans-serif;max-width:560px;margin:60px auto;padding:30px;border:1px solid #ddd;border-radius:10px">' +
        '<h2 style="color:#C0392B">⚠️ Dashboard file missing</h2>' +
        '<p>The API is running, but you need to add the dashboard HTML to this project:</p>' +
        '<ol style="line-height:1.9">' +
        '<li>In the Apps Script editor, click the <b>+</b> next to "Files"</li>' +
        '<li>Choose <b>HTML</b></li>' +
        '<li>Name it exactly: <b>Dashboard</b> (no .html)</li>' +
        '<li>Delete the default content, paste the full RHV dashboard HTML</li>' +
        '<li>Save, then <b>Deploy → Manage Deployments → Edit → New Version</b></li>' +
        '</ol></div>'
      );
    }
  }

  try {
    const role = validateToken(token);
    if (!role) return jsonOut({ error: 'Unauthorized', code: 401,
      hint: 'Token must be one of: rhv-admin-2024, rhv-revenue-2024, rhv-store-2024, rhv-payables-2024' });
    const year  = e.parameter.year  || '2025';
    const dept  = e.parameter.dept  || '';
    const month = parseInt(e.parameter.month || '-1');
    logAudit(role, action || 'all', dept);
    const result = dispatch(action || 'all', role, year, dept, month, e.parameter);
    return jsonOut(result);
  } catch (err) {
    return jsonOut({ error: err.message, line: err.lineNumber || 'unknown' });
  }
}

