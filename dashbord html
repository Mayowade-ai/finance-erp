function rExecAlerts() {
  const rev = gRev(), exp = gExp();
  const tRev = rev.reduce((a,b)=>a+b,0), tExp = exp.reduce((a,b)=>a+b,0);
  const latDeb = DB?.debtors?.latest || 0;
  const latRev = rev[10] || rev.filter(v=>v>0).slice(-1)[0] || 1;
  const debR = latDeb / latRev;
  const tgt = DB?.revenue?.['2025']?.target || 120000000;
  const latMonth = rev[10] || 0;
  const alerts = [];
  if (latDeb > 25e6) alerts.push({cls:'alrt-err',icon:'🔴',title:'Debtor Threshold Exceeded',detail:`Outstanding receivables ${fmt(latDeb)} exceeds ${fmt(25e6)} target by ${fmt(latDeb-25e6)}.`,action:'Review Debtors page'});
  if (debR > 0.2) alerts.push({cls:'alrt-warn',icon:'🟡',title:'Debtor/Revenue Ratio High',detail:`Ratio at ${(debR*100).toFixed(1)}% vs target of 20%.`,action:'Review collection procedures'});
  if (latMonth < tgt) alerts.push({cls:'alrt-warn',icon:'🟡',title:'Monthly Target Not Met',detail:`Latest month revenue ${fmt(latMonth)} below ${fmt(tgt)} target.`,action:'Review revenue streams'});
  if (tExp/tRev > 0.6) alerts.push({cls:'alrt-err',icon:'🔴',title:'Expense Ratio Critical',detail:`Expense ratio ${(tExp/tRev*100).toFixed(1)}% exceeds 60% threshold.`,action:'Review expenditure categories'});
  if (tRev > tgt * 11) alerts.push({cls:'alrt-navy',icon:'🟢',title:'YTD Revenue on Track',detail:`Total revenue ${fmt(tRev)} achieving ${(tRev/(tgt*11)*100).toFixed(0)}% of annual pace.`,action:'Continue monitoring'});
  const activeCount = alerts.filter(a=>a.cls!=='alrt-navy').length;
  document.getElementById('exec-kpis').innerHTML = `
    <div class="kc r"><div class="kl">Critical Alerts</div><div class="kv">${alerts.filter(a=>a.cls==='alrt-err').length}</div><div class="kd krd">Immediate action</div></div>
    <div class="kc a"><div class="kl">Warnings</div><div class="kv">${alerts.filter(a=>a.cls==='alrt-warn').length}</div><div class="kd kw">Monitor closely</div></div>
    <div class="kc g"><div class="kl">Positive</div><div class="kv">${alerts.filter(a=>a.cls==='alrt-navy').length}</div><div class="kd ku">On track</div></div>
    <div class="kc b"><div class="kl">Alert Threshold</div><div class="kv">₦1M</div><div class="kd ku">High-value trigger</div></div>`;
  document.getElementById('exec-alerts-list').innerHTML = alerts.map(a => `
    <div class="alrt-item ${a.cls}">
      <div style="font-size:20px;flex-shrink:0">${a.icon}</div>
      <div style="flex:1">
        <div style="font-weight:700;font-size:11px;margin-bottom:2px">${a.title}</div>
        <div style="font-size:10px;color:var(--text)">${a.detail}</div>
        <div style="font-size:9px;color:var(--muted);margin-top:3px">Recommended: ${a.action}</div>
      </div>
    </div>`).join('') || '<div style="padding:20px;text-align:center;color:var(--teal);font-weight:600">✅ No active alerts. All KPIs within target.</div>';
  const nb = document.getElementById('nb-exec');
  if (nb) { nb.textContent = activeCount; nb.style.display = activeCount ? 'inline' : 'none'; }
}
