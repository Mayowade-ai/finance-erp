function submitInvoice(){
  const cust=val('f-invCust'), amt=+val('f-invAmt');
  if(!cust||!amt){alert('Customer and amount required.');return false;}
  const vat=+val('f-invVat')||0; const total=amt*(1+vat/100);
  const needsAppr=val('f-invAppr')==='yes';
  const rec={ invNo:val('f-invNo'), date:val('f-invDate'), customer:cust, payerType:val('f-invPayer'),
    email:val('f-invEmail'), description:val('f-invDesc'), amount:amt, vat, vatAmount:amt*vat/100,
    total, dueDate:val('f-invDue'), needsAppr, apprBy:'', status:needsAppr?'Pending Approval':'Draft', ts:new Date().toISOString() };
  INVOICES.unshift(rec); saveLS('rhvInvoices',INVOICES);
  syncToSheet('Invoices', rec);
  addAuditEntry && addAuditEntry('Billing','Invoice Created', rec.invNo, '—', cust+' '+fmt(total));
  if(needsAppr){ addNotif && addNotif('Finance','🧾 Invoice '+rec.invNo+' awaiting COO/CEO approval — '+fmt(total),'warn'); notifyEvent && notifyEvent('Request Submitted','COO/CEO', rec.invNo+' invoice awaiting approval', deptEmail&&deptEmail('Administration')); }
  addNotif && addNotif('Billing','🧾 Invoice '+rec.invNo+' created — '+fmt(total),'info');
  postJournal('Invoice', rec.invNo, rec.date, 'Invoice '+rec.customer,[{acct:payerAR(rec.payerType),dr:rec.total},{acct:ACCT.REV,cr:rec.amount}].concat(rec.vatAmount?[{acct:'301000',cr:rec.vatAmount}]:[]));
