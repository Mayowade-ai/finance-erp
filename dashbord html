  try{
    const here=(window.location.href||'').split('?')[0];
    if(here.indexOf('/macros/')>-1&&here.indexOf('/exec')>-1)return here;
    // google.script sandbox: the parent (top) URL is the real /exec
    if(window.location.ancestorOrigins||document.referrer){
      const ref=(document.referrer||'').split('?')[0];
      if(ref.indexOf('/macros/')>-1&&ref.indexOf('/exec')>-1)return ref;
