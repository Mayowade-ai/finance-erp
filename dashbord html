function exportItemMaster() {
  const pharmaHead = ',Generic Name,Strength,Drug Type,Drug Group,Pack Size,Received In,Dispense In,In Med List,Batched,Income Head,Barcode';
  let csv = 'Code,Name,Category,Department,Rev-Gen,Cost,Selling,Reorder,Min,Max,Vendor' + pharmaHead + '\n';
  ITEMS.forEach(i => {
    const base = [
      i.code,'"' + i.name + '"', i.category, '"' + i.dept + '"',
      i.rev?'Yes':'No', i.cost, i.sell||0, i.reorder, i.min, i.max, '"' + (i.vendor||'') + '"'
    ].join(',');
    const pharma = i.category === 'Drug' ? [
      '','"'+(i.genericName||'')+'"', '"'+(i.strength||'')+'"', '"'+(i.drugType||'')+'"',
      '"'+(i.drugGroup||'')+'"', i.packSize||1, '"'+(i.receivedIn||'')+'"',
      '"'+(i.dispenseIn||'')+'"', i.inMedList?'Yes':'No', i.batchedInv?'Yes':'No',
      i.incomeHead||'', i.barcode||''
    ].join(',') : ',,,,,,,,,,,';
    csv += base + pharma + '\n';
  });
  typeof dlCSV === 'function' && dlCSV(csv, 'RHV_Item_Master_' + new Date().toISOString().slice(0,10) + '.csv');
