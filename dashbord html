function submitItemEnhanced() {
  const name = val('f-imName');
  if (!name) { alert('Item name is required.'); return false; }
  const cat = val('f-imCat');
  const isDrug = cat === 'Drug';
  const rec = {
    code:    val('f-imCode'),
    name,
    category: cat,
    dept:    val('f-imDept'),
    uom:     val('f-imUom'),
    rev:     val('f-imRev') === 'yes',
    cost:    +val('f-imCost') || 0,
    sell:    +val('f-imSell') || 0,
    reorder: +val('f-imReorder') || 0,
    min:     +val('f-imMin') || 0,
    max:     +val('f-imMax') || 0,
    vendor:  val('f-imVendor') || ''
  };
  if (isDrug) {
    Object.assign(rec, {
      genericName: val('f-imGeneric')  || '',
      strength:    val('f-imStrength') || '',
      drugType:    val('f-imDrugType') || '',
      drugGroup:   val('f-imDrugGroup')|| '',
      rxNomName:   val('f-imRxNom')    || '',
      rxcuiNo:     val('f-imRxCUI')    || '',
      packSize:    +val('f-imPackSize') || 1,
      receivedIn:  val('f-imRecvIn')   || 'Carton',
      dispenseIn:  val('f-imDispIn')   || 'Tablet',
      inMedList:   val('f-imMedList')  === 'yes',
      batchedInv:  val('f-imBatched')  === 'yes',
      incomeHead:  val('f-imIncomeHead')|| '601010',
      barcode:     val('f-imBarcode')  || ''
    });
  }
  ITEMS.unshift(rec);
  saveLS('rhvItems', ITEMS);
  if (typeof syncToSheet === 'function') syncToSheet('Item Master', rec);
  if (typeof addAuditEntry === 'function') addAuditEntry('Item Master', 'Item Created', '—', name, rec.code);
  rItemMaster();
  return true;
}
