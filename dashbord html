  var totRec = rows.filter(function(r){return r.type!=='payment';}).reduce(function(s,r){return s+(+r.amount||0);},0);
  var totPay = rows.filter(function(r){return r.type==='payment';}).reduce(function(s,r){return s+(+r.amount||0);},0);
