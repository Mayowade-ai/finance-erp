function submitRecv(){
  const item=val('f-srvItem'), qty=+val('f-srvQty'), cost=+val('f-srvCost');
  if(!item||!qty){alert('Item name and quantity are required.');return false;}
  const rec={
    srvNo:val('f-srvNo'), date:val('f-srvDate'), poRef:val('f-srvPO'),
    item, category:val('f-srvCat'), qty, unit:val('f-srvUnit'), unitCost:cost,
    vendor:val('f-srvVendor'), batch:val('f-srvBatch'), expiry:val('f-srvExp'),
    receivedBy:val('f-srvBy'), ts:new Date().toISOString()
  };
  SRV_RECEIPTS.unshift(rec); saveLS('rhvSRV',SRV_RECEIPTS);
  // Update stock register: add to existing item or create new line
  let s = STOCK_REG.find(x=>x.item.toLowerCase()===item.toLowerCase() && x.category===rec.category);
  if(s){ s.qty += qty; s.unitCost = cost||s.unitCost; s.lastReceived = rec.date; if(rec.expiry) s.expiry=rec.expiry; if(rec.batch) s.batch=rec.batch; }
  else { STOCK_REG.unshift({item, category:rec.category, qty, unit:rec.unit, unitCost:cost, batch:rec.batch, expiry:rec.expiry, lastReceived:rec.date, reorder:Math.max(10,Math.round(qty*0.2))}); }
  saveLS('rhvStockReg',STOCK_REG);
  // Mark PO received
  if(rec.poRef){ const po=PURCHASE_ORD.find(p=>p.poNo===rec.poRef); if(po){po.status='Received'; saveLS('rhvPO',PURCHASE_ORD);} }
  syncToSheet('SRV Report', rec);
  addAuditEntry && addAuditEntry('Stores','Item Received', rec.srvNo, '—', item+' ×'+qty);
  addNotif && addNotif('Stores','📥 '+item+' ×'+qty+' received into store','info');
  rStoreRecv(); rStockReg(); rSupplyChain(); rStoreKPIs();
  return true;
}
