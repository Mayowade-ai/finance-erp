/* ──────────────────────────────────────────────
   MESSAGE RENDERING
   ────────────────────────────────────────────── */
function adeFormatText(text) {
  // Simple markdown-like formatting
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/\x60([^\x60]+)\x60/g, '<code>$1</code>')
    .replace(/^### (.+)$/gm, '<div style="font-weight:800;color:var(--navy);margin:6px 0 2px;font-size:11px">$1</div>')
    .replace(/^## (.+)$/gm, '<div style="font-weight:800;color:var(--navy);margin:8px 0 3px;font-size:12px">$1</div>')
    .replace(/^- (.+)$/gm, '<div style="display:flex;gap:4px;margin:2px 0"><span style="color:var(--teal);flex-shrink:0">•</span><span>$1</span></div>')
    .replace(/^\d+\. (.+)$/gm, '<div style="margin:2px 0">$1</div>')
    .replace(/\n\n/g, '<br><br>')
    .replace(/\n/g, '<br>');
}
function adeRenderMsg(text, isMe, animate=true) {
  const time = new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});
  const initials = isMe ? (CU||'U').slice(0,2).toUpperCase() : 'AD';
  const html = `
    <div class="ade-msg ${isMe?'ade-me':''}" ${animate?'style="opacity:0;transform:translateY(8px);transition:.3s"':''}>
      <div class="ade-msg-av ${isMe?'ade-av-me':'ade-av-bot'}">${initials}</div>
      <div>
        <div class="ade-bubble ${isMe?'ade-bubble-me':'ade-bubble-bot'}">${isMe?escapeHtml(text):adeFormatText(text)}</div>
        <div class="ade-time ${isMe?'':'bot'}">${time}</div>
      </div>
    </div>`;
  // Render in both floating panel and full-page if open
  const targets = [
    document.getElementById('ade-msgs'),
    document.getElementById('ade-full-msgs')
  ].filter(Boolean);
  targets.forEach(el => {
    el.insertAdjacentHTML('beforeend', html);
    const added = el.lastElementChild;
    if (animate && added) {
      requestAnimationFrame(()=>{
        added.style.opacity = '1';
        added.style.transform = 'translateY(0)';
      });
    }
    el.scrollTop = el.scrollHeight;
  });
}
function adeShowTyping() {
  const html = `<div id="ade-typing" class="ade-msg">
    <div class="ade-msg-av ade-av-bot">AD</div>
    <div class="ade-bubble ade-bubble-bot"><div class="ade-typing"><span></span><span></span><span></span></div></div>
  </div>`;
  [document.getElementById('ade-msgs'), document.getElementById('ade-full-msgs')]
    .filter(Boolean).forEach(el=>{ el.insertAdjacentHTML('beforeend',html); el.scrollTop=el.scrollHeight; });
}
function adeRemoveTyping() {
  document.querySelectorAll('#ade-typing').forEach(el=>el.remove());
}
/* ──────────────────────────────────────────────
   SEND MESSAGE
   ────────────────────────────────────────────── */
async function adeSend(inputId='ade-input') {
  if (ADE_THINKING) return;
  const inputEl = document.getElementById(inputId);
  if (!inputEl) return;
  const msg = inputEl.value.trim();
  if (!msg) return;
  inputEl.value = '';
  if (inputId === 'ade-input') adeInputResize(inputEl);
  // New session if needed
  if (!ADE_CURRENT_SID) adeNewSession(msg);
  ADE_THINKING = true;
  const sendBtn = document.getElementById('ade-send-btn');
  if (sendBtn) sendBtn.disabled = true;
  // Show user message
  adeRenderMsg(msg, true);
  // Update history
  ADE_HISTORY.push({ role:'user', content: msg });
  // Show typing indicator
  adeShowTyping();
  try {
    const reply = await adeCallAPI(msg);
    adeRemoveTyping();
    adeRenderMsg(reply, false);
    ADE_HISTORY.push({ role:'assistant', content: reply });
    adeSaveSession();
    adeAuditLog(msg, reply.length);
    // Refresh session list in full page
    if (document.getElementById('ade-session-list')) adeRenderSessionList();
  } catch (err) {
    adeRemoveTyping();
    adeRenderMsg('⚠️ **Error:** ' + (err.message||'Something went wrong.') + '\n\nPlease check your internet connection or ADE settings. If using OpenAI or Gemini, verify your API key is configured in ADE Settings.', false);
  }
  ADE_THINKING = false;
  if (sendBtn) sendBtn.disabled = false;
}
/* ──────────────────────────────────────────────
   QUICK PROMPTS
   ────────────────────────────────────────────── */
function adeQuick(msg) {
  const inputEl = document.getElementById('ade-input');
  if (inputEl) inputEl.value = msg;
  adeSend();
}
function adeQuickFull(msg) {
  const inputEl = document.getElementById('ade-full-input');
  if (inputEl) inputEl.value = msg;
  adeSend('ade-full-input');
}
