function openDocWindow(title, html){
  let w=null;
  try{ w=window.open('','_blank','width=820,height=900'); }catch(e){ w=null; }
  if(w && w.document){
    w.document.open(); w.document.write(html); w.document.close();
    try{ w.focus(); }catch(e){}
    return;
  }
  // Pop-up blocked → offer the document as a downloadable HTML file instead
  try{
    const blob=new Blob([html],{type:'text/html;charset=utf-8'});
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a');
    a.href=url; a.download=(title||'document').replace(/[^\w\-]+/g,'_')+'.html';
    document.body.appendChild(a); a.click();
    setTimeout(()=>{document.body.removeChild(a);URL.revokeObjectURL(url);},1500);
    alert('Pop-ups are blocked, so the '+title+' was downloaded as an HTML file. Open it, then Print → Save as PDF.');
  }catch(e){ alert('Unable to open the document. Please allow pop-ups for this site.'); }
}
function emailDoc(email, subject, html, kind){
  // Always generate the document first so it is never blank.
  openDocWindow(subject, html);
  // If backend email is configured, send the full HTML doc server-side via MailApp.
  const token=TOKENS[CU]||''; const base=getURL().split('?')[0];
  if(email && token && base){
    fetch(base,{method:'POST',headers:{'Content-Type':'text/plain;charset=utf-8'},
      body:JSON.stringify({token,action:'email',to:email,subject,html}),redirect:'follow'})
      .then(r=>r.text())
      .then(()=>{ sT && sT('connSt',''); })
      .catch(()=>{});
    addNotif && addNotif('Billing','📧 '+subject+' emailed to '+email,'info');
  } else if(email){
    // No backend: let the user mail it themselves WITHOUT navigating away (open mail in a new tab)
    const body=encodeURIComponent('Please find your '+kind+' attached (use Print → Save as PDF from the document window that just opened, then attach it).');
    window.open('mailto:'+email+'?subject='+encodeURIComponent(subject)+'&body='+body,'_blank');
  }
}
