function actAppr(id, action) {
  const a = APPROVALS.find(x => x.id === id);
  if (!a) return;
  const label = action==='APPROVED'?'Approval':action==='REJECTED'?'Rejection':'Query';
  const comment = prompt(label+' comment'+(action==='QUERIED'?' (what clarification is needed?)':' (optional)')+':');
  if(action==='QUERIED' && !comment){alert('A query needs a comment.');return;}
  a.status = action;
  a.comments = comment || (action === 'APPROVED' ? 'Approved by Management.' : action==='REJECTED'?'Rejected by Management.':'Queried by Management.');
  localStorage.setItem('rhvApprovals', JSON.stringify(APPROVALS));
  addAuditEntry('Approvals', 'Request '+action, 'PENDING', action, 'APPR-'+id);
  // Sync the linked requisition lifecycle
  if(a.linkReq){
    const r=REQS.find(x=>x.reqNo===a.linkReq);
    if(r){
      if(action==='APPROVED'){ r.status='Pending Procurement'; r.stage='Pending Procurement'; r.history.push({stage:'Approved by Management → Procurement',ts:new Date().toISOString(),by:CU});
        notifyEvent('Request Approved', r.dept, r.reqNo+' approved — routed to Procurement', deptEmail(r.dept)); notifyEvent('PO Created','Procurement',r.reqNo+' awaiting PO', deptEmail('Procurement')); }
      else if(action==='REJECTED'){ r.status='Rejected'; r.stage='Rejected'; r.rejectReason=a.comments; r.history.push({stage:'Rejected: '+a.comments,ts:new Date().toISOString(),by:CU});
        notifyEvent('Request Rejected', r.dept, r.reqNo+' rejected: '+a.comments, deptEmail(r.dept)); }
      else if(action==='QUERIED'){ r.status='Queried'; r.stage='Submitted'; r.queryNote=a.comments; r.history.push({stage:'Queried: '+a.comments,ts:new Date().toISOString(),by:CU});
        notifyEvent('Request Queried', r.dept, r.reqNo+' queried: '+a.comments, deptEmail(r.dept)); }
      saveLS('rhvReqs',REQS); syncToSheet('Requisitions',r);
    }
  } else {
    addNotif('Finance', action==='APPROVED'?'🟢':action==='REJECTED'?'🔴':'🟠', 'Approval '+action+': '+a.title, fmt(a.amount)+' — '+a.comments, action==='APPROVED'?'info':'medium');
  }
  rApprovals();
}
