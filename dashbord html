function storeTab(name,el){
  document.querySelectorAll('#pg-store .da-tab').forEach(t=>t.classList.remove('on'));
  el.classList.add('on');
  document.querySelectorAll('#pg-store .stp').forEach(p=>p.classList.remove('on'));
  document.getElementById('stp-'+name).classList.add('on');
  if(name==='srv')rStoreRecv(); if(name==='reg')rStockReg();
  if(name==='out')rStockOut(); if(name==='exp')rExpired(); if(name==='kpi')rStoreKPIs();
}
function rStoreKPIs(){
  const totStock=STOCK_REG.reduce((s,r)=>s+(+r.qty*+r.unitCost||0),0);
  const low=STOCK_REG.filter(r=>+r.qty<=+r.reorder).length;
  const expired=EXPIRED.reduce((s,r)=>s+(+r.value||0),0);
  const issued=STOCK_OUT.reduce((s,r)=>s+(+r.value||0),0);
  const recv=SRV_RECEIPTS.reduce((s,r)=>s+(+r.qty*+r.unitCost||0),0);
  const expRatio=recv>0?(expired/recv*100):0;
  const k=document.getElementById('store-kpi-cards');
  if(k) k.innerHTML=`
    <div class="kc b"><div class="kl">Stock Value (on hand)</div><div class="kv">${fmt(totStock)}</div><div class="kd">${STOCK_REG.length} SKUs</div></div>
    <div class="kc g"><div class="kl">Total Received</div><div class="kv">${fmt(recv)}</div><div class="kd ku">${SRV_RECEIPTS.length} receipts</div></div>
    <div class="kc a"><div class="kl">Total Issued</div><div class="kv">${fmt(issued)}</div><div class="kd">${STOCK_OUT.length} issues</div></div>
    <div class="kc r"><div class="kl">Low-Stock Items</div><div class="kv">${low}</div><div class="kd ${low?'krd':'ku'}">need reorder</div></div>
    <div class="kc r"><div class="kl">Expired / Written-Off</div><div class="kv">${fmt(expired)}</div><div class="kd">${EXPIRED.length} records</div></div>
    <div class="kc ${expRatio<1?'g':'r'}"><div class="kl">Wastage Ratio</div><div class="kv">${expRatio.toFixed(2)}%</div><div class="kd ${expRatio<1?'ku':'krd'}">Target &lt;1%</div></div>`;
  // Charts
  const byCat={}; STOCK_REG.forEach(r=>byCat[r.category]=(byCat[r.category]||0)+(+r.qty*+r.unitCost||0));
  const ce=Object.entries(byCat).sort((a,b)=>b[1]-a[1]);
  dC('store-cat'); if(gc('store-cat')) CH['store-cat']=new Chart(gc('store-cat'),{type:'doughnut',data:{labels:ce.map(e=>e[0]),datasets:[{data:ce.map(e=>fM(e[1])),backgroundColor:COLORS,borderWidth:2,borderColor:'#fff'}]},options:{responsive:true,maintainAspectRatio:false,cutout:'55%',plugins:{legend:{position:'right',labels:{font:{size:10}}}}}});
  const byDept={}; STOCK_OUT.forEach(r=>byDept[r.dept]=(byDept[r.dept]||0)+(+r.value||0));
  const de=Object.entries(byDept).sort((a,b)=>b[1]-a[1]).slice(0,8);
  dC('store-issue'); if(gc('store-issue')) CH['store-issue']=new Chart(gc('store-issue'),{type:'bar',data:{labels:de.map(e=>e[0]),datasets:[{data:de.map(e=>fM(e[1])),backgroundColor:'#6C3483',borderRadius:4}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{callback:v=>'₦'+v+'M'}},y:{ticks:{font:{size:9}}}}}});
}
