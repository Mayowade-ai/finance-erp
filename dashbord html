<!DOCTYPE html>

<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width,initial-scale=1">

<title>RHV Hospital ERP Dashboard</title>

<link rel="preconnect" href="https://fonts.googleapis.com"><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

<style>

:root{--navy:#1B4F72;--teal:#117A65;--red:#C0392B;--amber:#CA6F1E;--purple:#6C3483;--green:#1E8449;--gold:#D4AC0D;--bg:#F4F6F9;--card:#fff;--border:#E0E4EA;--muted:#7F8C9A;--text:#1A2332;--sidebar:220px;}

*{box-sizing:border-box;margin:0;padding:0;}

body{font-family:'Inter','Segoe UI',Arial,sans-serif;background:var(--bg);color:var(--text);font-size:12px;}

/* LOGIN */

#LS{position:fixed;inset:0;background:linear-gradient(135deg,var(--navy) 0%,#0d2b45 100%);display:flex;align-items:flex-start;justify-content:center;z-index:9999;overflow-y:auto;padding:20px 0;}

.lb{background:#fff;border-radius:16px;margin:auto;padding:36px 40px;width:420px;box-shadow:0 20px 60px rgba(0,0,0,.4);}

.lb h1{color:var(--navy);font-size:22px;margin-bottom:4px;text-align:center;}

.lb .sub{color:var(--muted);text-align:center;font-size:11px;margin-bottom:22px;}

.rc{border:2px solid var(--border);border-radius:8px;padding:10px 14px;cursor:pointer;margin-bottom:8px;transition:.2s;display:flex;align-items:center;gap:10px;}

.rc:hover{border-color:var(--teal);background:#f0faf8;}

.rc.sel{border-color:var(--teal);background:var(--teal);color:#fff;transform:scale(1.01);box-shadow:0 4px 16px rgba(17,122,101,.3);}

.rc .ri{font-size:18px;}

.rc .rn{font-weight:700;font-size:12px;}

.rc .rd{font-size:10px;color:var(--muted);}.rc.sel .rn,.rc.sel .rd{color:rgba(255,255,255,.9);}

.pin-row{display:flex;gap:8px;align-items:center;margin:14px 0 8px;}

.pin-row input{flex:1;border:2px solid var(--border);border-radius:8px;padding:10px 14px;font-size:16px;letter-spacing:6px;outline:none;transition:.2s;}

.pin-row input:focus{border-color:var(--teal);}

.lb button{width:100%;padding:12px;background:var(--teal);color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:700;cursor:pointer;}

.lb button:hover{background:#0f6656;}#lerr{min-height:20px;font-size:13px;font-weight:700;color:#c0392b;background:#fdf2f2;border:1px solid #f5c6c6;border-radius:6px;padding:8px 12px;margin:4px 0;text-align:center;display:none;}#lerr:not(:empty){display:block;}
/* ─── LANDING PAGE (static CSS, always available) ───────── */
#rhv-landing{position:fixed;inset:0;z-index:99999;display:flex;flex-direction:column;align-items:center;justify-content:center;background:linear-gradient(135deg,#0a2540 0%,#1a4a7c 45%,#0d6e5a 100%);overflow:hidden;transition:opacity .5s ease,visibility .5s ease;}
#rhv-landing.lp-hide{opacity:0;visibility:hidden;pointer-events:none;}
.lp-logo-ring{font-size:72px;margin-bottom:16px;filter:drop-shadow(0 0 24px rgba(0,212,160,.4));}
.lp-hospital-name{font-size:28px;font-weight:800;color:#fff;text-align:center;letter-spacing:.5px;}
.lp-hospital-sub{font-size:13px;color:rgba(255,255,255,.65);margin:6px 0 24px;text-align:center;}
.lp-pills{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:32px;max-width:480px;}
.lp-pill{background:rgba(255,255,255,.12);color:rgba(255,255,255,.9);border:1px solid rgba(255,255,255,.2);border-radius:20px;padding:6px 14px;font-size:11px;font-weight:600;}
.lp-signin-btn{background:#00d4a0;color:#003322;border:none;border-radius:12px;padding:16px 48px;font-size:16px;font-weight:800;cursor:pointer;letter-spacing:.5px;box-shadow:0 8px 32px rgba(0,212,160,.4);transition:.2s;}
.lp-signin-btn:hover{background:#00f0b5;transform:translateY(-2px);}
.lp-tagline{margin-top:20px;font-size:11px;color:rgba(255,255,255,.4);text-align:center;}
.lp-version{margin-top:6px;font-size:10px;color:rgba(255,255,255,.25);text-align:center;}

#lerr{color:var(--red);font-size:11px;text-align:center;margin-top:8px;min-height:16px;}

/* TOPBAR */

#TB{display:none;position:fixed;top:0;left:0;right:0;height:52px;background:var(--navy);color:#fff;align-items:center;padding:0 18px;gap:14px;z-index:100;box-shadow:0 2px 8px rgba(0,0,0,.2);}

#TB .logo{font-size:16px;font-weight:800;color:#fff;letter-spacing:.5px;}

#TB .logo span{color:#4dd0b8;}

.ldot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}

.ldot.don{background:#2ecc71;}

.ldot.doff{background:#e74c3c;}

#TB .spacer{flex:1;}

.tbtn{background:rgba(255,255,255,.12);border:none;color:#fff;padding:5px 12px;border-radius:5px;cursor:pointer;font-size:11px;}

.tbtn:hover{background:rgba(255,255,255,.22);}

#trole{background:var(--teal);color:#fff;padding:4px 10px;border-radius:12px;font-size:10px;font-weight:700;}

#tsE{font-size:10px;color:rgba(255,255,255,.6);}

/* SIDEBAR */

#SB{display:none;position:fixed;top:52px;left:0;bottom:0;width:var(--sidebar);background:#1a2e42;overflow-y:auto;z-index:90;padding:10px 0;}

.ni{display:flex;align-items:center;gap:9px;padding:9px 18px;cursor:pointer;color:rgba(255,255,255,.75);font-size:11px;font-weight:500;transition:.15s;border-left:3px solid transparent;}

.ni:hover{background:rgba(255,255,255,.07);color:#fff;}

.ni.on{background:rgba(77,208,184,.12);color:#4dd0b8;border-left-color:#4dd0b8;}

.ni.lk{opacity:.35;cursor:not-allowed;}

.ni .ic{font-size:15px;width:20px;text-align:center;}

.ni .nb{margin-left:auto;background:var(--red);color:#fff;border-radius:8px;padding:1px 5px;font-size:9px;}

.nsep{padding:8px 18px 4px;font-size:9px;font-weight:700;color:rgba(255,255,255,.3);letter-spacing:1px;text-transform:uppercase;}

/* MAIN */

#MW{display:none;margin-left:var(--sidebar);margin-top:52px;padding:20px;min-height:calc(100vh - 52px);}

.pg{display:none;}

.pg.on{display:block;}

.ph{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px;}

.ph h2{font-size:18px;font-weight:800;color:var(--navy);}

.ph .ps{font-size:11px;color:var(--muted);}

/* CARDS */

.kgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;margin-bottom:18px;}

.kc{background:var(--card);border-radius:10px;padding:14px 16px;border-left:4px solid var(--teal);box-shadow:0 1px 4px rgba(0,0,0,.06);position:relative;}

.kc.g{border-left-color:var(--teal);}

.kc.r{border-left-color:var(--red);}

.kc.b{border-left-color:var(--navy);}

.kc.a{border-left-color:var(--amber);}

.kc.p{border-left-color:var(--purple);}

.kc.gd{border-left-color:var(--gold);}

.kl{font-size:10px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;}

.kv{font-size:18px;font-weight:800;color:var(--text);}

.kd{font-size:10px;margin-top:3px;}

.ku{color:var(--teal);}

.kw{color:var(--amber);}

.krd{color:var(--red);}

.kbg,.kbw,.kbr{position:absolute;top:10px;right:10px;padding:2px 6px;border-radius:8px;font-size:9px;font-weight:700;}

.kbg{background:#d4edda;color:#155724;}

.kbw{background:#fff3cd;color:#856404;}

.kbr{background:#f8d7da;color:#721c24;}

/* CHARTS */

.cgrid{display:grid;gap:14px;margin-bottom:16px;}

.cgrid.c2{grid-template-columns:1fr 1fr;}

.cgrid.c3{grid-template-columns:1fr 1fr 1fr;}

.cgrid.c4{grid-template-columns:1fr 1fr 1fr 1fr;}

.cbox{background:var(--card);border-radius:10px;padding:14px;box-shadow:0 1px 4px rgba(0,0,0,.06);}

.cbox h4{font-size:11px;font-weight:700;color:var(--navy);margin-bottom:10px;text-transform:uppercase;letter-spacing:.3px;}

.cbox canvas{max-height:200px;}

/* TABLES */

.tbox{background:var(--card);border-radius:10px;padding:14px;box-shadow:0 1px 4px rgba(0,0,0,.06);overflow-x:auto;margin-bottom:16px;}

.tbox h4{font-size:11px;font-weight:700;color:var(--navy);margin-bottom:10px;text-transform:uppercase;letter-spacing:.3px;}

table{width:100%;border-collapse:collapse;}

th{background:#f0f4f8;padding:7px 10px;text-align:left;font-size:10px;font-weight:700;color:var(--navy);text-transform:uppercase;letter-spacing:.3px;white-space:nowrap;}

td{padding:7px 10px;border-bottom:1px solid var(--border);font-size:11px;vertical-align:middle;}

tr:hover td{background:#f8fafc;}

tfoot td{font-weight:700;background:#f0f4f8;border-top:2px solid var(--border);}

/* TOOLBAR */

.fb{display:flex;align-items:center;gap:7px;flex-wrap:wrap;margin-bottom:14px;}

.fbn{padding:5px 12px;border:1.5px solid var(--border);border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;background:#fff;transition:.15s;}

.fbn:hover{border-color:var(--teal);}

.fbn.on{background:var(--teal);color:#fff;border-color:var(--teal);}

.fbd{padding:4px 10px;border:1.5px solid var(--border);border-radius:6px;font-size:11px;background:#fff;outline:none;}

.er{background:var(--card);border-radius:8px;padding:8px 14px;display:flex;align-items:center;gap:8px;margin-bottom:14px;flex-wrap:wrap;box-shadow:0 1px 3px rgba(0,0,0,.05);}

.ql{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;}

.qbtn{padding:4px 10px;border:1.5px solid var(--border);border-radius:5px;cursor:pointer;font-size:11px;background:#fff;}

.qbtn:hover{border-color:var(--navy);}

.qbtn.on{background:var(--navy);color:#fff;border-color:var(--navy);}

input[type=text],input[type=password],select{padding:6px 10px;border:1.5px solid var(--border);border-radius:6px;font-size:11px;outline:none;}

input:focus,select:focus{border-color:var(--teal);}

/* BADGES */

.badge{padding:2px 7px;border-radius:8px;font-size:9px;font-weight:700;display:inline-block;}

.badge.bg{background:#d4edda;color:#155724;}

.badge.bw{background:#fff3cd;color:#856404;}

.badge.br{background:#f8d7da;color:#721c24;}

.badge.bb{background:#d1ecf1;color:#0c5460;}

/* LEGEND */

.li{display:flex;align-items:center;gap:5px;font-size:10px;padding:2px 0;}

.ld{width:10px;height:10px;border-radius:2px;flex-shrink:0;}

/* DEPT ANALYSIS DRILLDOWN */

.chips{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px;}

.chip{padding:4px 10px;border-radius:14px;font-size:10px;font-weight:700;cursor:pointer;color:#fff;opacity:.75;transition:.15s;}

.chip:hover,.chip.on{opacity:1;box-shadow:0 2px 6px rgba(0,0,0,.2);}

.da-tabs{display:flex;gap:0;margin-bottom:12px;border-bottom:2px solid var(--border);}

.da-tab{padding:7px 16px;cursor:pointer;font-size:11px;font-weight:600;color:var(--muted);border-bottom:2px solid transparent;margin-bottom:-2px;}

.da-tab.on{color:var(--teal);border-bottom-color:var(--teal);}

.da-panel{display:none;}

.da-panel.on{display:block;}

.hr{display:grid;grid-template-columns:26px 1fr 90px 90px 90px 100px 60px 80px;gap:0;padding:5px 8px;border-bottom:1px solid var(--border);font-size:11px;align-items:center;}

.hr:hover{background:#f0f7ff;}

.hr.l0{font-weight:700;background:#f5f8fc;cursor:pointer;}

.hr.l1{background:#fafcff;cursor:pointer;font-size:10px;}

.hr.l2{background:#fff;font-size:10px;color:var(--navy);}

.hr.ltot{background:#e8f4f0;font-weight:700;font-size:11px;}

.ei{cursor:pointer;font-size:10px;color:var(--teal);}

.hidden{display:none!important;}

/* PERIODIC BUTTONS */

.pnb{padding:5px 12px;border:1.5px solid var(--border);border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;background:#fff;}

.pnb.on{background:var(--navy);color:#fff;border-color:var(--navy);}

.wv{display:none;}

.wk-cards{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;}

.wk-card{flex:1;min-width:80px;background:#fff;border:2px solid var(--border);border-radius:8px;padding:10px;text-align:center;cursor:pointer;}

.wk-card.on{border-color:var(--teal);background:#e8f8f5;}

.wk-n{font-size:10px;font-weight:700;color:var(--navy);}

.wk-r{font-size:14px;font-weight:800;color:var(--teal);margin:4px 0;}

.wk-d{font-size:9px;color:var(--muted);}

/* ARCHIVE */

.aitem{background:#fff;border:1.5px solid var(--border);border-radius:8px;padding:10px 14px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;}

.aitem:hover{border-color:var(--teal);}

.ebtn{padding:4px 10px;background:var(--navy);color:#fff;border:none;border-radius:5px;cursor:pointer;font-size:10px;}

/* SHEET TILES */

.stile{display:flex;align-items:center;gap:12px;background:#fff;border:1.5px solid var(--border);border-radius:10px;padding:14px;text-decoration:none;color:var(--text);transition:.2s;}

.stile:hover{border-color:var(--teal);box-shadow:0 2px 8px rgba(0,0,0,.08);}

.stile.lk{opacity:.5;pointer-events:none;}

.stile-icon{font-size:22px;}

.stile-name{font-weight:700;font-size:12px;}

.stile-desc{font-size:10px;color:var(--muted);}

#sheetGrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:10px;}

/* MOBILE SIDEBAR */

.ham{display:none;}

#SBoverlay{display:none;position:fixed;inset:52px 0 0 0;background:rgba(0,0,0,.45);z-index:85;}

@media(max-width:768px){

  .ham{display:inline-block;}

  #SB{width:240px!important;transform:translateX(-100%);transition:transform .25s ease;box-shadow:2px 0 16px rgba(0,0,0,.3);}

  #SB.open{transform:translateX(0);}

  #SBoverlay.show{display:block;}

  #MW{margin-left:0;padding:14px;}

  #TB{padding:0 10px;gap:8px;}

  #TB .logo{font-size:14px;}

  #yrS,#tsE{display:none;}

  .ph h2{font-size:16px;}

  .kgrid{grid-template-columns:1fr 1fr;}

  .frm{grid-template-columns:1fr;}

}

@media(max-width:420px){ .kgrid{grid-template-columns:1fr;} }

@media(max-width:768px){

  :root{--sidebar:0px;}

  #SB{width:200px;transform:translateX(-100%);}

  #MW{margin-left:0;}

  .cgrid.c2,.cgrid.c3,.cgrid.c4{grid-template-columns:1fr;}

  .hr{grid-template-columns:20px 1fr 70px 70px 80px;}

}

/* ── COMMUNICATION HUB ─────────────────────────────────────────── */

.msg-row{display:flex;align-items:flex-start;gap:10px;padding:9px 10px;border-radius:8px;cursor:pointer;margin-bottom:4px;transition:.15s;}

.msg-row:hover{background:var(--bg);}

.msg-unrd{background:#EBF5FB;border-left:3px solid var(--navy);}

.msg-dot{width:8px;height:8px;border-radius:50%;background:var(--navy);flex-shrink:0;margin-top:5px;}

.av{display:flex;align-items:center;justify-content:center;border-radius:50%;font-weight:700;flex-shrink:0;font-size:11px;}

.av-b{background:#D6EAF8;color:#1B4F72;}.av-g{background:#D5F5E3;color:#117A65;}

.av-r{background:#FADBD8;color:#C0392B;}.av-a{background:#FDEBD0;color:#CA6F1E;}

.ch-layout{display:flex;height:500px;border:1px solid var(--border);border-radius:10px;overflow:hidden;}

.ch-side{width:200px;border-right:1px solid var(--border);background:var(--bg);overflow-y:auto;flex-shrink:0;}

.ch-ni{display:flex;align-items:center;gap:7px;padding:7px 12px;cursor:pointer;font-size:11px;color:var(--muted);border-left:3px solid transparent;transition:.15s;}

.ch-ni:hover,.ch-ni.on{background:#fff;color:var(--teal);border-left-color:var(--teal);}

.ch-main{flex:1;display:flex;flex-direction:column;background:#fff;}

.bubble-me{background:var(--navy);color:#fff;border-radius:12px 0 12px 12px;padding:7px 10px;max-width:270px;font-size:11px;margin-left:auto;}

.bubble-them{background:var(--bg);color:var(--text);border-radius:0 12px 12px 12px;padding:7px 10px;max-width:270px;font-size:11px;border:1px solid var(--border);}

.notif-item{display:flex;gap:9px;padding:9px 12px;border-radius:8px;margin-bottom:5px;border:1px solid;}

.ni-info{background:var(--bg);border-color:var(--border);}

.ni-warn{background:#FFF9E6;border-color:#F4D03F;}

.ni-err{background:#FEECEC;border-color:#F1948A;}

.appr-card{border-radius:10px;border:1px solid var(--border);overflow:hidden;margin-bottom:10px;background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.06);}

.appr-hdr{padding:9px 14px;display:flex;align-items:center;gap:8px;}

.appr-bdy{padding:10px 14px;}

.appr-hi{border-color:var(--red)!important;}.appr-md{border-color:var(--amber)!important;}

.alrt-item{display:flex;gap:10px;padding:10px 12px;border-radius:0 8px 8px 0;margin-bottom:6px;border-left:4px solid;}

.alrt-navy{background:#EBF5FB;border-left-color:var(--navy);}

.alrt-warn{background:#FFF9E6;border-left-color:var(--amber);}

.alrt-err{background:#FEECEC;border-left-color:var(--red);}

.csrch{display:flex;align-items:center;gap:7px;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:6px 10px;}

.prs-on{display:inline-block;width:8px;height:8px;border-radius:50%;background:#27AE60;margin-right:3px;}

.prs-off{display:inline-block;width:8px;height:8px;border-radius:50%;background:#BDC3C7;margin-right:3px;}

/* ===== EXTENDED MODULES ===== */

.pmeta{font-size:11px;color:var(--muted);margin:-8px 0 14px;}

.bar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:12px;}

.bar .srch{padding:6px 10px;border:1.5px solid var(--border);border-radius:6px;font-size:11px;outline:none;min-width:200px;flex:0 1 260px;}

.bar .spacer{flex:1;}

.bar .muted{font-size:11px;color:var(--muted);}

.stp{display:none;} .stp.on{display:block;}

.frm{display:grid;grid-template-columns:1fr 1fr;gap:10px 14px;}

.frm label{display:flex;flex-direction:column;font-size:10px;font-weight:700;color:var(--navy);gap:3px;}

.frm label input,.frm label select{padding:7px 9px;border:1.5px solid var(--border);border-radius:6px;font-size:12px;font-weight:400;outline:none;}

.frm label input:focus,.frm label select:focus{border-color:var(--teal);}

#rhvModal{display:none;position:fixed;inset:0;z-index:9999;}

.mod-bg{position:absolute;inset:0;background:rgba(0,0,0,.45);}

.mod-box{position:relative;max-width:620px;margin:40px auto;background:#fff;border-radius:12px;box-shadow:0 20px 60px rgba(0,0,0,.35);max-height:88vh;display:flex;flex-direction:column;}

.mod-hd{padding:14px 18px;font-size:15px;font-weight:800;color:var(--navy);border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}

.mod-x{cursor:pointer;color:var(--muted);font-size:18px;}

.mod-bd{padding:18px;overflow-y:auto;}

.mod-ft{padding:12px 18px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;}

/* LINE ITEMS + UPLOAD */

.lit{width:100%;border-collapse:collapse;margin:6px 0;font-size:11px;}

.lit th{background:#eef3f8;padding:5px 6px;font-size:9px;text-align:left;color:var(--navy);}

.lit td{padding:3px 4px;border-bottom:1px solid var(--border);}

.lit input{width:100%;border:1px solid var(--border);border-radius:4px;padding:5px 6px;font-size:11px;}

.lit .rmln{background:var(--red);color:#fff;border:none;border-radius:4px;cursor:pointer;padding:3px 8px;}

.litfoot{font-weight:700;color:var(--navy);}

.upz{border:2px dashed var(--border);border-radius:8px;padding:12px;text-align:center;font-size:11px;color:var(--muted);cursor:pointer;}

.upz.has{border-color:var(--teal);color:var(--teal);background:#f0faf8;}

.upz input{display:none;}

/* ADE WIDGET */

#ade-fab{position:fixed;bottom:24px;right:24px;width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,#1B4F72,#117A65);border:none;cursor:pointer;z-index:8000;box-shadow:0 4px 20px rgba(0,0,0,.35);display:none;align-items:center;justify-content:center;transition:transform .2s}

#ade-fab:hover{transform:scale(1.08)}

.ade-fab-icon{font-size:26px}

#ade-badge{position:absolute;top:-4px;right:-4px;background:#C0392B;color:#fff;border-radius:50%;width:20px;height:20px;font-size:10px;font-weight:700;display:none;align-items:center;justify-content:center}

