// Post a balanced journal: lines = [{acct, dr, cr}], returns ref
function postJournal(source, ref, date, narration, lines){
  const totDr = lines.reduce((s,l)=>s+(+l.dr||0),0);
  const totCr = lines.reduce((s,l)=>s+(+l.cr||0),0);
  if(Math.abs(totDr-totCr) > 1){ console.warn('Unbalanced journal', ref, totDr, totCr); }
  lines.forEach(l=>{
    JOURNALS.unshift({ date:date||todayStr(), ref, source, acct:l.acct, acctName:acctName(l.acct),
      narration:narration||'', debit:+l.dr||0, credit:+l.cr||0, ts:new Date().toISOString() });
  });
  saveLS('rhvJournals', JOURNALS);
  syncToSheet('GL Journals', {ref, source, date:date||todayStr(), narration, debit:totDr, credit:totCr});
  return ref;
}
