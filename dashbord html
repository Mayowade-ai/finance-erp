function rFinStmt(){
  const src=document.getElementById('fs-src')?.value||'gl';
  // ---- gather figures ----
  let revenue=0, cos=0, staff=0, admin=0, util=0, repairs=0, deprec=0, other=0, capex=0;
  let assets=0, liabilities=0, equity=0, cash=0, ar=0, inv=0, ap=0;
  if(src==='gl' && (JOURNALS||[]).length){
    JOURNALS.forEach(j=>{
      const acc=COA.find(a=>a.c===j.acct)||{}; const k=(acc.k||'').toLowerCase(); const net=(j.debit||0)-(j.credit||0);
      if(acc.t==='I'){
        if(k.includes('revenue')) revenue+=-net;
        else if(k.includes('cost of sales')||k.includes('cost of services')||k.includes('direct cost')) cos+=net;
        else if(k.includes('staff')) staff+=net;
        else if(k.includes('administrative')||k.includes('professional')) admin+=net;
        else if(k.includes('depreciation')) deprec+=net;
        else if(k.includes('repairs')) repairs+=net;
        else other+=net;
      } else {
        if(k.includes('receivable')) ar+=net;
        else if(k.includes('inventory')) inv+=net;
        else if(k.includes('cash')) cash+=net;
        else if(k.includes('payable')||k.includes('liability')||k.includes('accrual')||k.includes('payroll')) liabilities+=-net;
        else if(k.includes('equity')||k.includes('capital')||k.includes('reserve')) equity+=-net;
        else if(net>0) assets+=net;
      }
    });
    assets += ar+inv+cash;
  } else {
    // data mode from dashboard
    const rev=gRev(), exp=gExp();
    revenue=rev.reduce((a,b)=>a+b,0);
    const tExp=exp.reduce((a,b)=>a+b,0);
    cos=Math.round(tExp*0.42); staff=Math.round(tExp*0.31); util=Math.round(tExp*0.12);
    capex=Math.round(tExp*0.06); admin=Math.round(tExp*0.05); repairs=Math.round(tExp*0.04);
    ar=DB?.debtors?.latest||0; cash=revenue-tExp-ar>0?revenue-tExp-ar:0; inv=Math.round(cos*0.25);
    assets=ar+cash+inv; ap=Math.round(cos*0.3); liabilities=ap; equity=assets-liabilities;
  }
  const grossProfit=revenue-cos;
  const totalOpex=staff+admin+util+repairs+deprec+other;
  const operatingProfit=grossProfit-totalOpex;
  const netProfit=operatingProfit;
  // ---- Income Statement ----
  const row=(lbl,val,bold,ind)=>'<tr'+(bold?' style="font-weight:700;background:#f0f4f8"':'')+'><td style="padding-left:'+(ind?24:10)+'px">'+lbl+'</td><td style="text-align:right">'+(val<0?'('+fmt(-val)+')':fmt(val))+'</td></tr>';
  document.getElementById('fs-is').innerHTML=
    '<div class="tbox"><h4>Income Statement — '+(src==='gl'?'GL Postings':'FY '+(document.getElementById('yrS')?.value||'2025'))+'</h4>'+
    '<table style="max-width:560px">'+
    row('Revenue',revenue,true)+
    row('Cost of Sales',-cos,false,true)+
    row('Gross Profit',grossProfit,true)+
    '<tr><td colspan="2" style="padding-top:8px;font-size:9px;color:var(--muted);text-transform:uppercase">Operating Expenses</td></tr>'+
    (staff?row('Staff Cost',-staff,false,true):'')+
    (admin?row('Administrative Expenses',-admin,false,true):'')+
    (util?row('Utilities',-util,false,true):'')+
    (repairs?row('Repairs & Maintenance',-repairs,false,true):'')+
    (deprec?row('Depreciation',-deprec,false,true):'')+
    (other?row('Other Costs',-other,false,true):'')+
    row('Total Operating Expenses',-totalOpex,true)+
    row('Operating Profit / (Loss)',operatingProfit,true)+
    row('Net Profit / (Loss)',netProfit,true)+
    '</table>'+
    '<div style="font-size:10px;color:var(--muted);margin-top:8px">Net margin: '+(revenue>0?(netProfit/revenue*100).toFixed(1):0)+'%</div></div>';
  // ---- Balance Sheet ----
  const totAssets=assets, totLiab=liabilities, totEq=(src==='gl')?(equity+netProfit):equity;
  document.getElementById('fs-bs').innerHTML=
    '<div class="tbox"><h4>Balance Sheet — '+(src==='gl'?'GL Postings':'as at period end')+'</h4>'+
    '<table style="max-width:560px">'+
    '<tr><td colspan="2" style="font-weight:700;color:var(--navy)">ASSETS</td></tr>'+
    (cash?row('Cash & Cash Equivalents',cash,false,true):'')+
    (ar?row('Accounts Receivable',ar,false,true):'')+
    (inv?row('Inventory',inv,false,true):'')+
    (assets-cash-ar-inv>0?row('Other Assets',assets-cash-ar-inv,false,true):'')+
    row('Total Assets',totAssets,true)+
    '<tr><td colspan="2" style="font-weight:700;color:var(--navy);padding-top:8px">LIABILITIES</td></tr>'+
    (ap?row('Accounts Payable',ap,false,true):'')+
    (liabilities-ap>0?row('Other Liabilities',liabilities-ap,false,true):'')+
    row('Total Liabilities',totLiab,true)+
    '<tr><td colspan="2" style="font-weight:700;color:var(--navy);padding-top:8px">EQUITY</td></tr>'+
    row('Retained Earnings / Equity',totEq,false,true)+
    row('Total Equity',totEq,true)+
    row('Total Liabilities + Equity',totLiab+totEq,true)+
    '</table>'+
    '<div style="font-size:10px;color:'+(Math.abs(totAssets-(totLiab+totEq))<totAssets*0.02?'var(--teal)':'var(--amber)')+';margin-top:8px">'+
