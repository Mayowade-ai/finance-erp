/* ──────────────────────────────────────────────
   API CALL
   ────────────────────────────────────────────── */
async function adeCallAPI(userMsg) {
  if (!ADE_CFG.enabled) {
    return 'ADE is currently disabled. An administrator can re-enable it in the ADE Settings.';
  }
  // Build message history
  const messages = [
    ...ADE_HISTORY.map(h=>({ role: h.role, content: h.content })),
    { role: 'user', content: userMsg }
  ];
  const provider = ADE_CFG.provider || 'claude';
  try {
    // ── Claude (Anthropic) — uses the built-in Artifact API ──
    if (provider === 'claude') {
      const resp = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model:      ADE_CFG.model || 'claude-sonnet-4-20250514',
          max_tokens: ADE_CFG.maxTokens || 1000,
          system:     adeSystemPrompt(),
          messages:   messages
        })
      });
      if (!resp.ok) {
        const err = await resp.json().catch(()=>({error:{message:'API error '+resp.status}}));
        throw new Error(err?.error?.message || 'API error ' + resp.status);
      }
      const data = await resp.json();
      const text = data.content?.filter(c=>c.type==='text').map(c=>c.text).join('') || '';
      // Update usage
      ADE_CFG.usageTokens += (data.usage?.input_tokens||0) + (data.usage?.output_tokens||0);
      ADE_CFG.usageCount  += 1;
      ADE_SAVE_CFG();
      return text;
    }
    // ── OpenAI ──
    if (provider === 'openai') {
      if (!ADE_CFG.apiKey) throw new Error('OpenAI API key not configured. Add it in ADE Settings.');
      const resp = await fetch('https://api.openai.com/v1/chat/completions', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + ADE_CFG.apiKey
        },
        body: JSON.stringify({
          model:       ADE_CFG.openaiModel || 'gpt-4o-mini',
          max_tokens:  ADE_CFG.maxTokens || 1000,
          temperature: ADE_CFG.temperature || 0.7,
          messages:    [{ role:'system', content: adeSystemPrompt() }, ...messages]
        })
      });
      if (!resp.ok) {
        const err = await resp.json().catch(()=>({error:{message:'API error '+resp.status}}));
        throw new Error(err?.error?.message || 'OpenAI API error ' + resp.status);
      }
      const data = await resp.json();
      ADE_CFG.usageTokens += data.usage?.total_tokens || 0;
      ADE_CFG.usageCount  += 1;
      ADE_SAVE_CFG();
      return data.choices?.[0]?.message?.content || '';
    }
    // ── Google Gemini ──
    if (provider === 'gemini') {
      if (!ADE_CFG.apiKey) throw new Error('Gemini API key not configured. Add it in ADE Settings.');
      const geminiModel = ADE_CFG.geminiModel || 'gemini-1.5-flash';
      const resp = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/${geminiModel}:generateContent?key=${ADE_CFG.apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            systemInstruction: { parts: [{ text: adeSystemPrompt() }] },
            contents: messages.map(m=>({
              role: m.role === 'assistant' ? 'model' : 'user',
              parts: [{ text: m.content }]
            }))
          })
        }
      );
      if (!resp.ok) {
        const err = await resp.json().catch(()=>({error:{message:'Gemini API error '+resp.status}}));
        throw new Error(err?.error?.message || 'Gemini API error ' + resp.status);
      }
      const data = await resp.json();
      ADE_CFG.usageCount += 1;
      ADE_SAVE_CFG();
      return data.candidates?.[0]?.content?.parts?.[0]?.text || '';
    }
    throw new Error('Unknown API provider: ' + provider);
  } catch (err) {
    console.warn('ADE API error:', err);
    throw err;
  }
}
