/* ═════════════════════════════════════════════════════
   SECTION 2 — Replace p2pCanAct() function
════════════════════════════════════════════════════════ */
function p2pCanAct(r) {
  if (CU === 'admin' || CU === 'coo' || CU === 'ceo') return true;
  const s = r.status;
  const map = {
    'Submitted':                          ['coo', 'ceo'],
    'Pending Management Approval':        ['coo', 'ceo'],
    'Awaiting Procurement Action':        ['procurement'],
    'Procurement Review':                 ['procurement'],
    'Awaiting Final Management Approval': ['coo', 'ceo'],
    'Vendor Approved':                    ['procurement'],
    'Purchase Order Issued':              ['procurement'],
    'Vendor Confirmed':                   ['store'],
    'Delivered':                          ['store'],
    'Goods Received':                     ['procurement'],
    'Awaiting Payment':                   ['payables'],
    'Payment Processing':                 ['payables'],
    'Paid':                               ['admin', 'coo', 'ceo']
  };
  return (map[s] || []).includes(CU);
}
/* ═══════════════════════════════════════════════════════
   SECTION 3 — Replace p2pApprove() function
   (Two-gate approval logic)
════════════════════════════════════════════════════════ */
function p2pApprove(no) {
  const r = p2pFind(no);
  if (!r) return;
  const s = r.status;
  const c = prompt('Approval remark (optional):') || 'Approved';
  if (s === 'Submitted' || s === 'Pending Management Approval') {
    // ── GATE 1: First Management Approval ──
    // Management approves the need before Procurement begins sourcing
    r.status = 'Approved';
    p2pLog(r, 'Gate 1 — Management Approved', c);
    r.status = 'Awaiting Procurement Action';
    p2pLog(r, 'Routed to Procurement', 'Begin vendor sourcing and RFQ');
    p2pSave();
    addAudit_if_available('Procurement', 'Gate 1 Approved', no, c, r.prNo);
    notifyEvent && notifyEvent('Request Approved', 'Procurement',
      r.prNo + ' — Gate 1 approved. Begin vendor sourcing.',
      deptEmail && deptEmail('Procurement'));
    notifyEvent && notifyEvent('Request Approved', r.dept,
      r.prNo + ' — approved by Management. Procurement is now sourcing.',
      '');
  } else if (s === 'Awaiting Final Management Approval') {
    // ── GATE 2: Final Management Approval ──
    // Management approves Procurement's vendor recommendation
    const selectedVendor = r.vendor || (r.quotes && r.quotes.find(q => q.selected) ? r.quotes.find(q => q.selected).vendor : 'TBD');
    r.status = 'Vendor Approved';
    p2pLog(r, 'Gate 2 — Vendor Selection Approved', 'Vendor: ' + selectedVendor + ' · ' + c);
    p2pSave();
    addAudit_if_available('Procurement', 'Gate 2 — Vendor Approved', no, selectedVendor, r.prNo);
    notifyEvent && notifyEvent('Vendor Approved', 'Procurement',
      r.prNo + ' — vendor approved. Issue Purchase Order.',
      deptEmail && deptEmail('Procurement'));
  }
  updateP2PBadge && updateP2PBadge();
  rP2P && rP2P();
  if (p2pCurrent === no) openP2PDetail && openP2PDetail(no);
}
