async function refAll(){
  try{
    const token=TOKENS[CU]||'';
    if(!token){DB=buildDemo();setLive(false);rAll();return;}
    // Sanitize URL: strip any existing query params before adding ours
    const baseURL = getURL().split('?')[0];
    const yr = document.getElementById('yrS')?.value||'2025';
    const url = `${baseURL}?token=${token}&action=all&year=${yr}`;
    const resp = await fetch(url,{redirect:'follow'});
    const text = await resp.text();
    let j;
    try{j=JSON.parse(text);}catch{const m=text.match(/\{[\s\S]*\}/);j=m?JSON.parse(m[0]):{};}
    // If we get a "status" response it means the token wasn’t sent (URL issue)
    if(j.status && !j.revenue){
      throw new Error('API reachable but token not received — check URL has no extra params');
    }
    if(j.error)throw new Error(j.error);
    DB=j;setLive(true);saveSnap(DB);
    sT('connSt','');
  }catch(e){
    console.warn('API fallback:',e.message);
    DB=buildDemo();setLive(false);
  }
  rAll();
  sT('tsE','Updated '+new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'}));
  clearInterval(window._ar);window._ar=setInterval(refAll,60000);
}
