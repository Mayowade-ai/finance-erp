function submitIssue(){
  const sel=val('f-isItem'); const [item,cat]=sel.split('|'); const qty=+val('f-isQty');
  if(!item||!qty){alert('Select an item and quantity.');return false;}
  const s=STOCK_REG.find(x=>x.item===item && x.category===cat);
  if(!s){alert('Item not found in stock.');return false;}
  if(qty>+s.qty){alert('Cannot issue '+qty+' — only '+s.qty+' in stock.');return false;}
  s.qty -= qty; saveLS('rhvStockReg',STOCK_REG);
  const rec={ issueNo:val('f-isNo'), date:val('f-isDate'), item, category:cat, qty, unit:s.unit,
    unitCost:s.unitCost, value:qty*s.unitCost, dept:val('f-isDept'), purpose:val('f-isPurpose'),
    issuedBy:val('f-isBy'), ts:new Date().toISOString() };
  STOCK_OUT.unshift(rec); saveLS('rhvStockOut',STOCK_OUT);
  if(rec.value>0) postJournal('Stock Issue', rec.issueNo, rec.date, 'Issue '+item+' to '+rec.dept,[{acct:catCosAcct(cat),dr:rec.value},{acct:catInvAcct(cat),cr:rec.value}]);
  syncToSheet('Stock Out', rec);
  addAuditEntry && addAuditEntry('Stores','Item Issued', rec.issueNo, s.qty+qty+' in stock', s.qty+' remaining');
  addNotif && addNotif('Stores','📤 '+item+' ×'+qty+' issued to '+rec.dept,'info');
  if(+s.qty<=+s.reorder) addNotif && addNotif('Stores','⚠ Low stock: '+item+' ('+s.qty+' left)','warn');
  rStockReg(); rStockOut(); rStoreKPIs(); rSupplyChain();
  return true;
}
