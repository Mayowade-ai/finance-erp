    '<div style="font-size:11px;color:var(--muted);margin-bottom:8px">Three ways to import:<br>1) <b>Download template</b>, fill it in Excel, save as CSV, then choose the file.<br>2) Choose any <b>.csv</b> file.<br>3) <b>Copy rows from Excel/Google Sheets and paste</b> below (tabs or commas both work). Header row optional.</div>'+
    '<div class="bar"><button class="ebtn" onclick="impTemplate()">⬇ Download Template</button>'+
    '<label class="ebtn" style="background:var(--navy);cursor:pointer">📂 Choose CSV<input type="file" accept=".csv,.txt,.tsv" style="display:none" onchange="impFile(this)"></label></div>'+
    '<div style="font-size:10px;font-weight:700;color:var(--navy);margin:6px 0 3px">Columns: '+d.headers.join(' · ')+'</div>'+
    '<textarea id="imp-paste" rows="9" placeholder="Paste rows here…" style="width:100%;border:1px solid var(--border);border-radius:6px;padding:8px;font-size:11px;font-family:monospace" oninput="impPreview()"></textarea>'+
    '<div id="imp-preview" style="font-size:11px;margin-top:8px"></div>',
    impCommit);
}
function impTemplate(){ const d=IMPORT_DEFS[_impType]; dlCSV(d.headers.join(',')+'\n', d.title.replace(/\s/g,'_')+'_Template.csv'); }
function impFile(inp){ const f=inp.files[0]; if(!f)return; const r=new FileReader(); r.onload=()=>{document.getElementById('imp-paste').value=r.result; impPreview();}; r.readAsText(f); }
function impSplit(line){ if(line.indexOf('\t')>-1)return line.split('\t'); const out=[];let cur='',q=false; for(const ch of line){ if(ch==='"')q=!q; else if(ch===','&&!q){out.push(cur);cur='';} else cur+=ch; } out.push(cur); return out; }
function impParse(){
  const d=IMPORT_DEFS[_impType];
  const lines=(document.getElementById('imp-paste')?.value||'').split(/\r?\n/).map(l=>l.trim()).filter(Boolean);
  const rows=[]; let errs=[];
  lines.forEach((ln,i)=>{
    const c=impSplit(ln).map(x=>x.trim().replace(/^"|"$/g,''));
    if(i===0 && d.headers.some(hd=>ln.toLowerCase().includes(hd.toLowerCase().split('(')[0].trim().toLowerCase())) && isNaN(+c[ d.cols.indexOf('cost')>=0?d.cols.indexOf('cost'):1 ])) return; // skip header row
    const rec=d.make(c);
    const firstField=d.cols[0]==='patient'?rec.meal:(rec.name||rec.item||rec.asset||rec.code);
    if(!firstField){ errs.push('Line '+(i+1)+': missing required name/item'); return; }
    rows.push(rec);
  });
  return {rows,errs};
}
function impPreview(){
  const {rows,errs}=impParse();
  const p=document.getElementById('imp-preview'); if(!p)return;
  let html='<div style="color:var(--teal);font-weight:700">✓ '+rows.length+' valid row(s) ready'+(errs.length?' · <span style="color:var(--red)">'+errs.length+' error(s)</span>':'')+'</div>';
  if(rows.length){ const d=IMPORT_DEFS[_impType];
