// ---- Local data stores (offline-first; sync to backend when connected) ----
let SRV_RECEIPTS = JSON.parse(localStorage.getItem('rhvSRV')      || '[]');
let STOCK_REG    = JSON.parse(localStorage.getItem('rhvStockReg') || '[]');
let STOCK_OUT    = JSON.parse(localStorage.getItem('rhvStockOut') || '[]');
let EXPIRED      = JSON.parse(localStorage.getItem('rhvExpired')  || '[]');
let PURCHASE_ORD = JSON.parse(localStorage.getItem('rhvPO')       || '[]');
let INVOICES     = JSON.parse(localStorage.getItem('rhvInvoices') || '[]');
let RECEIPTS     = JSON.parse(localStorage.getItem('rhvReceipts') || '[]');
const saveLS = (k,v)=>{try{localStorage.setItem(k,JSON.stringify(v));}catch(e){}};
const todayStr = ()=>new Date().toISOString().slice(0,10);
const genID = (pre)=>pre+'-'+Date.now().toString().slice(-6)+Math.floor(Math.random()*90+10);
const escapeHtml = s=>String(s==null?'':s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
// ---- Push a record to the backend Sheet (best-effort; silent if offline) ----
async function syncToSheet(sheet, record){
  try{
    const token = TOKENS[CU] || '';
    const base  = getURL().split('?')[0];
    if(!token || !base) return false;
    await fetch(base, {
      method:'POST',
      headers:{'Content-Type':'text/plain;charset=utf-8'}, // text/plain avoids CORS preflight
      body: JSON.stringify({ token, action:'append', sheet, record }),
      redirect:'follow'
    });
    return true;
  }catch(e){ console.warn('sync failed', e.message); return false; }
}
