function rP2P(){ p2pInitFilters(); rP2PStats(); rP2PQueue(); rP2PMine(); updateP2PBadge(); }
function p2pTab(t,el){ p2pTabMode=t; document.querySelectorAll('#pg-p2p .da-tab').forEach(x=>x.classList.remove('on')); el.classList.add('on');
  document.querySelectorAll('#pg-p2p .stp').forEach(p=>p.classList.remove('on')); document.getElementById('p2ptp-'+t).classList.add('on');
  if(t==='queue')rP2PQueue(); if(t==='mine')rP2PMine(); if(t==='analytics')rP2PAnalytics(); if(t==='detail'&&p2pCurrent)openP2PDetail(p2pCurrent); }
function p2pInitFilters(){
  const ss=document.getElementById('p2p-fstatus');
  if(ss && ss.options.length<=1){ P2P_FLOW.concat(P2P_TERMINAL).forEach(s=>{const o=document.createElement('option');o.value=s;o.textContent=s;ss.appendChild(o);}); }
  const ds=document.getElementById('p2p-fdept');
  if(ds && ds.options.length<=1){ DEPT_NAMES.forEach(d=>{const o=document.createElement('option');o.value=d;o.textContent=d;ds.appendChild(o);}); }
}
function updateP2PBadge(){
  // count items awaiting THIS user's action
  const n=P2P.filter(r=>p2pCanAct(r)&&!P2P_TERMINAL.includes(r.status)&&r.status!=='Completed').length;
  const b=document.getElementById('nb-p2p'); if(b){b.textContent=n;b.style.display=n?'inline':'none';}
}
function rP2PStats(){
  const c=s=>P2P.filter(r=>r.status===s).length;
  const pend=P2P.filter(r=>['Submitted','Pending Department Approval','Pending COO Approval','Pending CEO Approval'].includes(r.status)).length;
  document.getElementById('p2p-stats').innerHTML=
    '<div class="kc a"><div class="kl">Pending Approval</div><div class="kv">'+pend+'</div></div>'+
    '<div class="kc b"><div class="kl">Procurement</div><div class="kv">'+(c('Approved')+c('Procurement Review')+c('Vendor Sourcing')+c('Vendor Selected')+c('Purchase Order Raised'))+'</div></div>'+
    '<div class="kc r"><div class="kl">Awaiting Payment</div><div class="kv">'+(c('Awaiting Payment')+c('Payment Processing'))+'</div></div>'+
    '<div class="kc g"><div class="kl">Paid</div><div class="kv">'+c('Paid')+'</div></div>'+
    '<div class="kc p"><div class="kl">Goods Received</div><div class="kv">'+(c('Goods Received')+c('Delivered')+c('Partially Delivered'))+'</div></div>'+
    '<div class="kc g"><div class="kl">Completed</div><div class="kv">'+c('Completed')+'</div></div>'+
    '<div class="kc b"><div class="kl">Total Value</div><div class="kv">'+fmt(P2P.reduce((s,r)=>s+(+r.amount||0),0))+'</div></div>'+
    '<div class="kc r"><div class="kl">Cancelled/Rejected</div><div class="kv">'+(c('Cancelled')+c('Rejected'))+'</div></div>';
}
function p2pRowActionBtn(r){
  // contextual primary action for the queue
  const no=r.prNo;
  if(!p2pCanAct(r)) return '<button class="ebtn" style="padding:2px 8px;background:var(--navy)" onclick="openP2PDetail(\''+no+'\')">View</button>';
  let label='Action';
  if(['Submitted','Pending Department Approval','Pending COO Approval','Pending CEO Approval'].includes(r.status)) label='Review';
  else if(r.status==='Approved') label='Assign';
  else if(['Procurement Review','Vendor Sourcing','Vendor Selected'].includes(r.status)) label='Source/PO';
  else if(r.status==='Purchase Order Raised') label='Raise Payment';
  else if(['Awaiting Payment','Payment Processing'].includes(r.status)) label='Pay';
  else if(['Paid','Partially Delivered','Delivered'].includes(r.status)) label='Receive';
  else if(r.status==='Goods Received') label='Complete';
  return '<button class="ebtn" style="padding:2px 8px" onclick="openP2PDetail(\''+no+'\')">'+label+'</button>';
}
function rP2PQueue(){
  p2pInitFilters();
  const q=(document.getElementById('p2p-srch')?.value||'').toLowerCase();
  const fs=document.getElementById('p2p-fstatus')?.value||'';
  const fd=document.getElementById('p2p-fdept')?.value||'';
  let rows=P2P.filter(r=>(!q||(r.prNo+r.dept+r.item+r.vendor+r.requesterLbl).toLowerCase().includes(q))&&(!fs||r.status===fs)&&(!fd||r.dept===fd));
  // non-admin/procurement: only see relevant queue items
  document.getElementById('p2p-queue-tb').innerHTML=rows.length?rows.map(r=>{
    const pr=r.priority==='Urgent'?'br':r.priority==='High'?'bw':'bb';
    return '<tr><td style="font-weight:600">'+r.prNo+'</td><td>'+r.date+'</td><td>'+escapeHtml(r.dept)+'</td><td>'+escapeHtml(r.requesterLbl||r.requester)+'</td><td>'+escapeHtml(r.item)+'</td><td>'+fmt(r.amount)+'</td><td><span class="badge '+pr+'">'+r.priority+'</span></td><td><span class="badge '+p2pBadge(r.status)+'">'+r.status+'</span></td><td style="font-size:10px">'+escapeHtml(r.assigned||'—')+'</td><td>'+p2pRowActionBtn(r)+'</td></tr>';
  }).join(''):'<tr><td colspan="10" style="text-align:center;color:var(--muted);padding:20px">No requests. Click "＋ New Request".</td></tr>';
}
function rP2PMine(){
  const mine=P2P.filter(r=>CU==='admin'||r.requester===CU||r.dept===(ROLES[CU]?.lbl.replace(' Unit','')));
  const c=document.getElementById('p2p-mine-ct'); if(c)c.textContent=mine.length+' requests';
  document.getElementById('p2p-mine-tb').innerHTML=mine.length?mine.map(r=>
    '<tr><td style="font-weight:600">'+r.prNo+'</td><td>'+r.date+'</td><td>'+escapeHtml(r.item)+'</td><td>'+fmt(r.amount)+'</td><td><span class="badge '+p2pBadge(r.status)+'">'+r.status+'</span></td><td><button class="ebtn" style="padding:2px 8px;background:var(--navy)" onclick="openP2PDetail(\''+r.prNo+'\')">View</button></td></tr>'
  ).join(''):'<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:20px">No requests yet.</td></tr>';
}
/* ---------- DETAIL + TIMELINE + ACTIONS ---------- */
function openP2PDetail(no){
  p2pCurrent=no; const r=p2pFind(no); if(!r) return;
  // switch to detail tab
  document.querySelectorAll('#pg-p2p .da-tab').forEach((x,i)=>x.classList.toggle('on', x.textContent.includes('Detail')));
  document.querySelectorAll('#pg-p2p .stp').forEach(p=>p.classList.remove('on'));
  document.getElementById('p2ptp-detail').classList.add('on');
  const ci=p2pStageIndex(r.status); const rejected=P2P_TERMINAL.includes(r.status);
  // timeline
  const tl=P2P_FLOW.map((s,i)=>{
    const done=!rejected&&i<=ci, cur=i===ci&&!rejected;
    return '<div style="display:flex;align-items:center;gap:8px;padding:3px 0">'+
      '<span style="width:20px;height:20px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0;background:'+(done?'var(--teal)':'#e0e4ea')+';color:'+(done?'#fff':'#999')+'">'+(done?'✓':(i+1))+'</span>'+
      '<span style="font-size:11px;'+(cur?'font-weight:700;color:var(--navy)':done?'color:var(--text)':'color:var(--muted)')+'">'+s+'</span></div>';
  }).join('');
  // line items
  const lit='<table class="lit" style="margin:0"><thead><tr><th>Item</th><th>Description</th><th>Qty</th><th>Unit Price</th><th style="text-align:right">Total</th></tr></thead><tbody>'+
    (r.lines||[]).map(l=>'<tr><td>'+escapeHtml(l.item)+'</td><td>'+escapeHtml(l.desc||'')+'</td><td>'+l.qty+'</td><td>'+fmt(l.price)+'</td><td style="text-align:right">'+fmt(l.total)+'</td></tr>').join('')+
    '<tr class="litfoot"><td colspan="4" style="text-align:right">TOTAL</td><td style="text-align:right">'+fmt(r.amount)+'</td></tr></tbody></table>';
  // quotations
  let quo='';
  if(['Vendor Sourcing','Vendor Selected','Procurement Review','Purchase Order Raised'].includes(r.status)||r.quotes.length){
    quo='<div class="tbox"><h4>Quotations '+((CU==='admin'||CU==='procurement')?'<button class="ebtn" style="padding:2px 8px;float:right" onclick="p2pAddQuote(\''+no+'\')">＋ Add Quote</button>':'')+'</h4>'+
      '<table><thead><tr><th>Vendor</th><th>Amount</th><th>Lead (days)</th><th>Notes</th><th></th></tr></thead><tbody>'+
      (r.quotes.length?r.quotes.map((qt,i)=>'<tr style="'+(qt.selected?'background:#e8f8f5':'')+'"><td>'+escapeHtml(qt.vendor)+(qt.selected?' ✓':'')+'</td><td>'+fmt(qt.amount)+'</td><td>'+qt.lead+'</td><td style="font-size:10px">'+escapeHtml(qt.notes||'')+'</td><td>'+((CU==='admin'||CU==='procurement')&&!qt.selected?'<button class="ebtn" style="padding:2px 8px" onclick="p2pSelectVendor(\''+no+'\','+i+')">Select</button>':'')+'</td></tr>').join(''):'<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:12px">No quotations yet.</td></tr>')+
      '</tbody></table></div>';
  }
  // audit timeline (history)
  const aud='<div class="tbox"><h4>Audit Trail (read-only)</h4><table><thead><tr><th>Date / Time</th><th>User</th><th>Role</th><th>Action</th><th>Remarks</th></tr></thead><tbody>'+
    (r.history||[]).slice().reverse().map(e=>'<tr><td style="font-size:10px;white-space:nowrap">'+new Date(e.ts).toLocaleString('en-GB',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'})+'</td><td>'+escapeHtml(e.user)+'</td><td><span class="badge bb">'+escapeHtml(e.role)+'</span></td><td>'+escapeHtml(e.action)+'</td><td style="font-size:10px;color:var(--muted)">'+escapeHtml(e.remarks||'')+'</td></tr>').join('')+
    '</tbody></table></div>';
  document.getElementById('p2p-detail-body').innerHTML=
    '<div class="bar"><button class="ebtn" style="background:var(--border);color:var(--text)" onclick="p2pTab(\'queue\',document.querySelector(\'#pg-p2p .da-tab\'))">← Back to Queue</button>'+
    '<button class="ebtn" style="background:var(--teal)" onclick="printP2P(\''+no+'\')">🖨 Print / PDF</button>'+
    (r.attachment?'<button class="ebtn" style="background:var(--amber)" onclick="openAttachment(\''+no+'\')">📎 Attachment</button>':'')+
    '<span class="spacer"></span><span class="badge '+p2pBadge(r.status)+'" style="font-size:11px">'+r.status+'</span></div>'+
    '<div class="cgrid c2">'+
      '<div class="cbox"><h4>'+r.prNo+' · '+escapeHtml(r.dept)+'</h4>'+
        '<div style="font-size:11px;line-height:1.9"><b>Requestor:</b> '+escapeHtml(r.requesterLbl||r.requester)+'<br><b>Date:</b> '+r.date+'<br><b>Priority:</b> '+r.priority+'<br><b>Vendor:</b> '+escapeHtml(r.vendor||'—')+'<br><b>PO:</b> '+escapeHtml(r.poNo||'—')+'<br><b>Payment Ref:</b> '+escapeHtml(r.payRef||'—')+(r.payMethod?' ('+r.payMethod+')':'')+'<br><b>Notes:</b> '+escapeHtml(r.notes||'—')+'</div>'+
        '<div style="margin-top:10px">'+lit+'</div></div>'+
      '<div class="cbox"><h4>Workflow Timeline</h4>'+tl+'</div>'+
    '</div>'+
    p2pActionBar(r)+
    quo+aud;
}
function p2pActionBar(r) {
  const no = r.prNo;
  if (P2P_TERMINAL.includes(r.status)) {
    return '<div class="cbox" style="margin-bottom:14px;color:var(--red);font-weight:700">' +
      'This request is ' + r.status + '. No further action is possible.</div>';
  }
  if (r.status === 'Completed') {
    return '<div class="cbox" style="margin-bottom:14px;color:var(--teal);font-weight:700">' +
      '✓ Completed — transaction fully processed and closed.</div>';
  }
  if (!p2pCanAct(r)) {
    return '<div class="cbox" style="margin-bottom:14px;color:var(--muted)">' +
      'Awaiting action by the responsible role for: <b>' + r.status + '</b>.</div>';
  }
  const s = r.status;
  let btns = '';
  if (s === 'Submitted' || s === 'Pending Management Approval') {
    // GATE 1 — Management first review
    btns = '<button class="ebtn" style="background:var(--teal)" onclick="p2pApprove(\'' + no + '\')">' +
              '&#9989; Gate 1: Approve Request</button> ' +
           '<button class="ebtn" style="background:var(--amber)" onclick="p2pQuery(\'' + no + '\')">' +
              '&#128992; Request Clarification</button> ' +
           '<button class="ebtn" style="background:var(--red)" onclick="p2pReject(\'' + no + '\')">' +
              '&#10060; Reject</button>';
  } else if (s === 'Awaiting Procurement Action' || s === 'Approved') {
    btns = '<button class="ebtn" onclick="p2pAdvance(\'' + no + '\',\'Procurement Review\',\'Vendor sourcing started — RFQ issued\')">' +
              '&#128269; Begin Vendor Sourcing &amp; RFQ</button>';
  } else if (s === 'Procurement Review') {
    const hasQuotes = r.quotes && r.quotes.length > 0;
    const hasVendor = r.quotes && r.quotes.some(q => q.selected);
    btns = '<button class="ebtn" onclick="p2pAddQuote(\'' + no + '\')">&#43; Add Quotation</button> ';
    if (hasQuotes) {
      btns += '<button class="ebtn" style="background:var(--navy)" onclick="p2pSubmitRecommendation(\'' + no + '\')">' +
                '&#128203; Submit Recommendation to Management</button>';
    } else {
      btns += '<span style="font-size:11px;color:var(--muted);margin-left:8px">Add at least one quotation before submitting recommendation</span>';
    }
  } else if (s === 'Awaiting Final Management Approval') {
    // GATE 2 — Management approves vendor selection
    btns = '<button class="ebtn" style="background:var(--teal)" onclick="p2pApprove(\'' + no + '\')">' +
              '&#9989; Gate 2: Approve Vendor &amp; Proceed to PO</button> ' +
           '<button class="ebtn" style="background:var(--amber)" onclick="p2pRequestAltVendor(\'' + no + '\')">' +
              '&#128257; Request Alternative Vendor</button> ' +
           '<button class="ebtn" style="background:var(--red)" onclick="p2pReject(\'' + no + '\')">' +
              '&#10060; Reject</button>';
  } else if (s === 'Vendor Approved') {
    btns = '<button class="ebtn" onclick="p2pRaisePO(\'' + no + '\')">' +
              '&#128196; Issue Purchase Order</button>';
  } else if (s === 'Purchase Order Issued') {
    btns = '<button class="ebtn" onclick="p2pAdvance(\'' + no + '\',\'Vendor Confirmed\',\'Vendor acknowledged receipt of PO\')">' +
              '&#10003; Vendor Confirmed PO</button>';
  } else if (s === 'Vendor Confirmed') {
    btns = '<button class="ebtn" onclick="p2pAdvance(\'' + no + '\',\'Delivered\',\'Vendor delivered goods to Store\')">' +
              '&#128666; Mark as Delivered</button>';
  } else if (s === 'Delivered') {
    btns = '<button class="ebtn" onclick="p2pMarkGoodsReceived(\'' + no + '\', false)">' +
              '&#128229; Receive Full Delivery</button> ' +
           '<button class="ebtn" style="background:var(--amber)" onclick="p2pMarkGoodsReceived(\'' + no + '\', true)">' +
              '&#9888; Receive Partial Delivery</button>';
  } else if (s === 'Goods Received') {
    // Show payment gate status before allowing raise
    const issues = p2pPaymentGateCheck(r);
    if (issues.length > 0) {
      btns = '<div style="background:#FFF9E6;border:1px solid #F4D03F;border-radius:6px;padding:10px;margin-bottom:8px;font-size:11px">' +
               '<b>&#9888; Payment Gate — Action Required:</b><br>' +
               issues.map(i => '&#8226; ' + i).join('<br>') + '</div>' +
             '<button class="ebtn" onclick="p2pUploadVendorInvoice(\'' + no + '\')">' +
               '&#128196; Upload Vendor Invoice</button>';
    } else {
      btns = '<div style="background:#EAF3DE;border:1px solid #3B6D11;border-radius:6px;padding:8px 10px;margin-bottom:8px;font-size:11px">' +
               '&#10003; All payment gate conditions met. Payment request can now be raised.</div>' +
             '<button class="ebtn" style="background:var(--teal)" onclick="p2pRaisePaymentGated(\'' + no + '\')">' +
               '&#128179; Raise Payment Request to Finance</button>';
    }
  } else if (s === 'Awaiting Payment') {
    btns = '<button class="ebtn" onclick="p2pAdvance(\'' + no + '\',\'Payment Processing\',\'AP processing payment\')">' +
              '&#9203; Process Payment</button> ' +
           '<button class="ebtn" style="background:var(--amber)" onclick="p2pHoldPayment(\'' + no + '\')">' +
              '&#128274; Hold Payment</button> ' +
           '<button class="ebtn" onclick="p2pUploadVendorInvoice(\'' + no + '\')">' +
              '&#128196; Upload / Update Invoice</button>';
  } else if (s === 'Payment Processing') {
    btns = '<button class="ebtn" style="background:var(--teal)" onclick="p2pMarkPaid(\'' + no + '\')">' +
              '&#9989; Mark as Paid</button>';
  } else if (s === 'Paid') {
    btns = '<button class="ebtn" style="background:var(--teal)" onclick="p2pComplete(\'' + no + '\')">' +
              '&#10003; Mark Completed &amp; Close</button>';
  }
  return '<div class="cbox" style="margin-bottom:14px">' +
    '<h4 style="margin-bottom:10px">Actions — ' + escapeHtml(s) + '</h4>' +
    btns +
    ' <button class="ebtn" style="background:#95A5A6;margin-left:6px" onclick="p2pCancel(\'' + no + '\')">' +
    'Cancel Request</button></div>';
}
function printP2P(no){
  const r=p2pFind(no); if(!r) return;
  const lines=(r.lines||[]).map(l=>'<tr><td>'+escapeHtml(l.item)+'</td><td>'+escapeHtml(l.desc||'')+'</td><td style="text-align:right">'+l.qty+'</td><td style="text-align:right">'+fmt(l.price)+'</td><td style="text-align:right">'+fmt(l.total)+'</td></tr>').join('');
  const hist=(r.history||[]).map(e=>'<tr><td>'+new Date(e.ts).toLocaleString()+'</td><td>'+escapeHtml(e.user)+'</td><td>'+escapeHtml(e.action)+'</td><td>'+escapeHtml(e.remarks||'')+'</td></tr>').join('');
  openDocWindow('P2P '+no, docShell('Procurement Request '+no,
    '<div class="hdr"><div><h1><img src="'+RHV_LOGO+'" style="width:34px;height:34px;vertical-align:middle;margin-right:6px">RHV Hospital</h1><div class="sub">Procure-to-Pay Record · Lagos, Nigeria</div></div><div><div class="docttl">'+no+'</div><div class="sub" style="text-align:right">'+r.status+'</div></div></div>'+
    '<div class="meta"><div><b>Department:</b> '+escapeHtml(r.dept)+'</div><div style="text-align:right"><b>Date:</b> '+r.date+'</div><div><b>Requestor:</b> '+escapeHtml(r.requesterLbl||r.requester)+'</div><div style="text-align:right"><b>Vendor:</b> '+escapeHtml(r.vendor||'—')+'</div><div><b>PO:</b> '+escapeHtml(r.poNo||'—')+'</div><div style="text-align:right"><b>Priority:</b> '+r.priority+'</div></div>'+
    '<table><thead><tr><th>Item</th><th>Description</th><th style="text-align:right">Qty</th><th style="text-align:right">Unit</th><th style="text-align:right">Total</th></tr></thead><tbody>'+lines+'</tbody></table>'+
    '<div class="tot"><span class="grand">TOTAL: '+fmt(r.amount)+'</span></div>'+
    '<h3 style="margin-top:24px;color:#1B4F72">Audit Trail</h3><table><thead><tr><th>Date/Time</th><th>User</th><th>Action</th><th>Remarks</th></tr></thead><tbody>'+hist+'</tbody></table>'));
}
/* ---------- ANALYTICS ---------- */
function rP2PAnalytics(){
  const byDept={}; P2P.forEach(r=>byDept[r.dept]=(byDept[r.dept]||0)+(+r.amount||0));
  const de=Object.entries(byDept).sort((a,b)=>b[1]-a[1]);
  dC('p2p-dept-ch'); if(gc('p2p-dept-ch')) CH['p2p-dept-ch']=new Chart(gc('p2p-dept-ch'),{type:'bar',data:{labels:de.map(e=>e[0]),datasets:[{data:de.map(e=>fM(e[1])),backgroundColor:COLORS,borderRadius:4}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{callback:v=>'₦'+v+'M'}}}}});
  const byV={}; P2P.forEach(r=>{if(r.vendor)byV[r.vendor]=(byV[r.vendor]||0)+(+r.amount||0);});
  const ve=Object.entries(byV).sort((a,b)=>b[1]-a[1]).slice(0,8);
  dC('p2p-vend-ch'); if(gc('p2p-vend-ch')) CH['p2p-vend-ch']=new Chart(gc('p2p-vend-ch'),{type:'bar',data:{labels:ve.map(e=>e[0]),datasets:[{data:ve.map(e=>fM(e[1])),backgroundColor:'#117A65',borderRadius:4}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{callback:v=>'₦'+v+'M'}}}}});
  const byS={}; P2P.forEach(r=>byS[r.status]=(byS[r.status]||0)+1);
  const se=Object.entries(byS);
  dC('p2p-pipe-ch'); if(gc('p2p-pipe-ch')) CH['p2p-pipe-ch']=new Chart(gc('p2p-pipe-ch'),{type:'doughnut',data:{labels:se.map(e=>e[0]),datasets:[{data:se.map(e=>e[1]),backgroundColor:COLORS,borderWidth:2,borderColor:'#fff'}]},options:{responsive:true,maintainAspectRatio:false,cutout:'55%',plugins:{legend:{position:'right',labels:{font:{size:9}}}}}});
  const byM={}; P2P.forEach(r=>{const m=(r.date||'').slice(0,7); if(m)byM[m]=(byM[m]||0)+(+r.amount||0);});
  const me=Object.entries(byM).sort();
  dC('p2p-trend-ch'); if(gc('p2p-trend-ch')) CH['p2p-trend-ch']=new Chart(gc('p2p-trend-ch'),{type:'line',data:{labels:me.map(e=>e[0]),datasets:[{data:me.map(e=>fM(e[1])),borderColor:'#CA6F1E',backgroundColor:'rgba(202,111,30,.1)',fill:true,tension:.3,borderWidth:2}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{y:{ticks:{callback:v=>'₦'+v+'M'}}}}});
  const out=P2P.filter(r=>['Awaiting Payment','Payment Processing','Purchase Order Raised'].includes(r.status));
  document.getElementById('p2p-outstanding-tb').innerHTML=out.length?out.map(r=>'<tr><td>'+r.prNo+'</td><td>'+escapeHtml(r.vendor||'—')+'</td><td>'+fmt(r.amount)+'</td><td>'+r.date+'</td><td><span class="badge '+p2pBadge(r.status)+'">'+r.status+'</span></td></tr>').join(''):'<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:16px">No outstanding payments.</td></tr>';
}
function exportP2P(){
  if(!P2P.length){alert('No data to export.');return;}
  let csv='PR No,Date,Department,Requestor,Item,Amount,Priority,Status,Vendor,PO No,Payment Ref\n';
