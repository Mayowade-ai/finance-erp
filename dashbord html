/* ──────────────────────────────────────────────────────────────
   LOGIN FIX
   The original doLogin wrapper in Part 4C may break login if
   the original function uses 'this' or relies on being called
   directly.  This safer version defers the wrapper to DOMContentLoaded
   so all functions are fully initialised first.
   ────────────────────────────────────────────────────────────── */
(function() {
  function _safeWrapLogin() {
    const orig = window.doLogin;
    if (typeof orig !== 'function') return;          // nothing to wrap
    if (orig.__adeWrapped) return;                   // already wrapped — skip
    window.doLogin = function() {
      orig.apply(this, arguments);                   // forward all args + context
      setTimeout(function() {
        try { if (typeof applyBrandToUI === 'function') applyBrandToUI(); } catch(e) {}
        try { if (typeof adeInit === 'function') adeInit(); }              catch(e) {}
        try { if (typeof buildBrandingSettings === 'function') buildBrandingSettings(); } catch(e) {}
      }, 300);
    };
    window.doLogin.__adeWrapped = true;
  }
  // Run immediately (Part 5 is parsed after all other code)
  _safeWrapLogin();
  // Also re-run on DOMContentLoaded as safety net
  document.addEventListener('DOMContentLoaded', _safeWrapLogin);
})();
