function _drawCashCharts() {
  if (typeof Chart === 'undefined') return;
  var today     = typeof todayStr === 'function' ? todayStr() : new Date().toISOString().slice(0,10);
  var thisMonth = today.slice(0,7);
  // ── Daily trend (last 14 days) ──
  var days = [];
  for (var i = 13; i >= 0; i--) {
    var d = new Date(); d.setDate(d.getDate() - i);
    days.push(d.toISOString().slice(0,10));
  }
  var dayTotals = days.map(function(day) {
    return CASHBOOK_ENTRIES
      .filter(function(e) { return e.date === day && e.type !== 'payment'; })
      .reduce(function(s,e) { return s + (+e.amount||0); }, 0);
  });
  var c1 = document.getElementById('cash-trend-chart');
  if (c1) {
    if (window._cashTrendCh) { window._cashTrendCh.destroy(); }
    window._cashTrendCh = new Chart(c1, {
      type: 'bar',
      data: {
        labels: days.map(function(d) { return d.slice(5); }),
        datasets: [{
          data: dayTotals.map(function(v) { return +(v/1e6).toFixed(2); }),
          backgroundColor: dayTotals.map(function(v) { return v > 0 ? '#117A65' : '#e8ecf0'; }),
          borderRadius: 3
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { grid: { display: false }, ticks: { font: { size: 9 }, maxRotation: 45 } },
          y: { grid: { color: 'rgba(0,0,0,.05)' }, ticks: { callback: function(v) { return '₦'+v+'M'; } } }
        }
      }
    });
  }
  // ── Department breakdown (this month) ──
  var deptMap = {};
  CASHBOOK_ENTRIES
    .filter(function(e) { return (e.date||'').slice(0,7) === thisMonth && e.type !== 'payment'; })
    .forEach(function(e) {
      var d = e.dept || 'Other';
      deptMap[d] = (deptMap[d] || 0) + (+e.amount || 0);
    });
  var deptEntries = Object.entries(deptMap).sort(function(a,b){return b[1]-a[1];}).slice(0,8);
  var c2 = document.getElementById('cash-dept-chart');
  if (c2 && deptEntries.length) {
    if (window._cashDeptCh) { window._cashDeptCh.destroy(); }
    var COLORS = ['#1B4F72','#117A65','#6C3483','#CA6F1E','#D85A30','#639922','#1ABC9C','#F39C12'];
    window._cashDeptCh = new Chart(c2, {
      type: 'doughnut',
      data: {
        labels: deptEntries.map(function(e){return e[0];}),
        datasets: [{
          data: deptEntries.map(function(e){return +(e[1]/1e6).toFixed(2);}),
          backgroundColor: COLORS,
          borderWidth: 2, borderColor: '#fff'
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        cutout: '55%',
        plugins: { legend: { position: 'right', labels: { font: { size: 10 } } } }
      }
    });
  }
}
