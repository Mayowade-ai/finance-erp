// ── Logo upload handler ───────────────────────────────────────
function brLogoUpload(inp) {
  var file = inp.files[0];
  if (!file) return;
  if (file.size > 500 * 1024) {
    alert('Logo file must be under 500 KB. Please compress the image and try again.');
    inp.value = '';
    return;
  }
  var reader = new FileReader();
  reader.onload = function() {
    var b = getBrand();
    b.logo = reader.result;
    saveBrand(b);
    var prev = document.getElementById('br-logo-preview');
    if (prev) prev.innerHTML = '<img src="' + b.logo + '" style="max-width:68px;max-height:68px;object-fit:contain;border-radius:4px">';
    applyBrandToUI();
    var st = document.getElementById('br-st');
    if (st) { st.textContent = '✅ Logo uploaded and applied to all documents.'; }
    if (typeof addAuditEntry === 'function') addAuditEntry('System', 'Logo Uploaded', '—', file.name, 'BRAND');
  };
  reader.readAsDataURL(file);
}
