/* ── STEP 4: Replace rItemMaster() ─────────────────────────── */
function rItemMaster() {
  const rev   = ITEMS.filter(i => i.rev).length;
  const drugs = ITEMS.filter(i => i.category === 'Drug').length;
  const kEl = document.getElementById('im-kpi');
  if (kEl) kEl.innerHTML =
    '<div class="kc b"><div class="kl">Total Items</div><div class="kv">' + ITEMS.length + '</div></div>' +
    '<div class="kc g"><div class="kl">Drugs</div><div class="kv">' + drugs + '</div></div>' +
    '<div class="kc a"><div class="kl">Consumables &amp; Reagents</div><div class="kv">' + (ITEMS.length - drugs) + '</div></div>' +
    '<div class="kc p"><div class="kl">Revenue-Generating</div><div class="kv">' + rev + '</div></div>' +
    '<div class="kc r"><div class="kl">Departments Covered</div><div class="kv">' + new Set(ITEMS.map(i => i.dept)).size + '</div></div>';
  const filterVal = document.getElementById('im-filter')?.value || '';
  const q = (document.getElementById('im-srch')?.value || '').toLowerCase();
  let rows = ITEMS.filter(i =>
    !q || (i.code + i.name + i.dept + (i.genericName||'') + (i.strength||'')).toLowerCase().includes(q)
  );
  if (filterVal === 'rev')      rows = rows.filter(i => i.rev);
  else if (filterVal === 'nonrev') rows = rows.filter(i => !i.rev);
  else if (filterVal)            rows = rows.filter(i => i.category === filterVal);
  const tb = document.getElementById('im-tb');
  if (!tb) return;
  const viewingDrug = filterVal === 'Drug' || rows.some(i => i.category === 'Drug');
  // Dynamic table header
  const thead = tb.closest('table')?.querySelector('thead tr');
  if (thead) {
    thead.innerHTML =
      '<th>Code</th><th>Name</th><th>Category</th><th>Dept</th><th>Rev</th>' +
      '<th>Cost</th><th>Selling</th><th>Reorder</th><th>Min</th><th>Max</th><th>Vendor</th>' +
      (viewingDrug ? '<th>Generic</th><th>Strength</th><th>Type</th><th>Group</th><th>Disp. Unit</th>' : '');
  }
  tb.innerHTML = rows.length ? rows.map(i => {
    const pharmaCols = viewingDrug
      ? (i.category === 'Drug'
          ? '<td>' + escapeHtml(i.genericName||'—') + '</td>' +
            '<td>' + escapeHtml(i.strength||'—') + '</td>' +
            '<td><span class="badge bb">' + escapeHtml(i.drugType||'—') + '</span></td>' +
            '<td style="font-size:10px">' + escapeHtml(i.drugGroup||'—') + '</td>' +
            '<td><span class="badge bg">' + escapeHtml(i.dispenseIn||i.uom||'—') + '</span></td>'
          : '<td colspan="5" style="color:var(--muted)">—</td>')
      : '';
    return '<tr>' +
      '<td>' + escapeHtml(i.code) + '</td>' +
      '<td style="font-weight:600">' + escapeHtml(i.name) + '</td>' +
      '<td><span class="badge bb">' + escapeHtml(i.category) + '</span></td>' +
      '<td>' + escapeHtml(i.dept) + '</td>' +
      '<td><span class="badge ' + (i.rev?'bg':'bw') + '">' + (i.rev?'Yes':'No') + '</span></td>' +
      '<td>' + fmt(i.cost) + '</td>' +
      '<td>' + (i.sell ? fmt(i.sell) : '—') + '</td>' +
      '<td>' + i.reorder + '</td>' +
      '<td>' + i.min + '</td>' +
      '<td>' + i.max + '</td>' +
      '<td style="font-size:10px">' + escapeHtml(i.vendor||'—') + '</td>' +
      pharmaCols +
    '</tr>';
  }).join('') :
  '<tr><td colspan="16" style="text-align:center;color:var(--muted);padding:20px">No items match the current filter.</td></tr>';
}
