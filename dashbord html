  if (typeof GRNS !== 'undefined' && typeof genID === 'function') {
    const grnNo = genID('GRN');
    const totalQty = r.lines ? r.lines.reduce((s, l) => s + (+l.qty || 0), 0) : 0;
    const grnRec = {
      grnNo,
      date: receivedDate,
      poRef: r.poNo || r.prNo,
      vendor: r.vendor || '',
      item: r.item,
      category: (r.lines && r.lines[0]) ? (r.lines[0].desc || 'Procurement') : 'Procurement',
      poQty: totalQty,
      recvQty: totalQty,
      match: partial ? 'Partial' : 'Full',
      condition: 'Good',
      batch: '',
      expiry: '',
      receivedBy: (typeof ROLES !== 'undefined' && ROLES[CU]) ? ROLES[CU].lbl : CU,
      linkP2P: no,
      ts: new Date().toISOString()
    };
    GRNS.unshift(grnRec);
    if (typeof saveLS === 'function') saveLS('rhvGRN', GRNS);
    r.grnRef = grnNo;
  }
  // Add SRV receipt if item can be tracked in Store Register
  if (typeof SRV_RECEIPTS !== 'undefined' && r.lines && typeof genID === 'function') {
    r.lines.forEach(function(line) {
      if (!line.item) return;
      const srvRec = {
        srvNo: genID('SRV'),
        date: receivedDate,
        poRef: r.poNo || r.prNo,
        item: line.item,
        category: line.desc || 'Procurement',
        qty: +line.qty || 0,
        unit: 'Units',
        unitCost: +line.price || 0,
        vendor: r.vendor || '',
        batch: '',
        expiry: '',
        receivedBy: (typeof ROLES !== 'undefined' && ROLES[CU]) ? ROLES[CU].lbl : CU,
        ts: new Date().toISOString()
      };
      SRV_RECEIPTS.unshift(srvRec);
      // Update stock register
      if (typeof STOCK_REG !== 'undefined') {
        const existing = STOCK_REG.find(function(s) {
          return s.item && s.item.toLowerCase() === line.item.toLowerCase();
        });
        if (existing) {
          existing.qty = (+existing.qty || 0) + (+line.qty || 0);
          existing.lastReceived = receivedDate;
        } else {
          STOCK_REG.unshift({
            item: line.item,
            category: line.desc || 'Procurement',
            qty: +line.qty || 0,
            unit: 'Units',
            unitCost: +line.price || 0,
            reorder: 0,
            batch: '',
            expiry: '',
            lastReceived: receivedDate
          });
        }
        if (typeof saveLS === 'function') saveLS('rhvStockReg', STOCK_REG);
