// ---- ordered lifecycle stages ----
const P2P_FLOW = [
  'Draft',
  'Submitted',
  'Pending Management Approval',       // Management reviews department request
  'Approved',                           // Gate 1 passed — routed to Procurement
  'Awaiting Procurement Action',        // Procurement begins work
  'Procurement Review',                 // Vendor sourcing, RFQ, quotation collection
  'Awaiting Final Management Approval', // Procurement recommendation returned to Management
  'Vendor Approved',                    // Gate 2 passed — Procurement issues PO
  'Purchase Order Issued',              // PO sent to vendor
  'Vendor Confirmed',                   // Vendor acknowledged PO
  'Delivered',                          // Vendor delivered goods to Store
  'Goods Received',                     // Store confirmed receipt, GRN created
  'Awaiting Payment',                   // Procurement raised payment request (all 4 gate conditions met)
  'Payment Processing',                 // Accounts Payable processing
  'Paid',                               // Payment completed
  'Completed'                           // Transaction closed
];
const P2P_TERMINAL = ['Rejected', 'Cancelled'];
// status → badge colour class
function p2pBadge(s){
  if(s==='Completed'||s==='Goods Received'||s==='Paid'||s==='Delivered') return 'bg';
  if(s==='Rejected'||s==='Cancelled') return 'br';
  if(s==='Approved'||s==='Vendor Selected'||s==='Purchase Order Raised') return 'bb';
  return 'bw';
}
function p2pStageIndex(s){ const i=P2P_FLOW.indexOf(s); return i<0?0:i; }
// who can act at each stage (role keys). admin can always act.
function p2pCanAct(r) {
  if (CU === 'admin' || CU === 'coo' || CU === 'ceo') return true;
  const s = r.status;
  const map = {
    'Submitted':                          ['coo', 'ceo'],
    'Pending Management Approval':        ['coo', 'ceo'],
    'Awaiting Procurement Action':        ['procurement'],
    'Procurement Review':                 ['procurement'],
    'Awaiting Final Management Approval': ['coo', 'ceo'],
    'Vendor Approved':                    ['procurement'],
    'Purchase Order Issued':              ['procurement'],
    'Vendor Confirmed':                   ['store'],
    'Delivered':                          ['store'],
    'Goods Received':                     ['procurement'],
    'Awaiting Payment':                   ['payables'],
    'Payment Processing':                 ['payables'],
    'Paid':                         ['admin','payables']
  };
  return (map[s] || []).includes(CU);
}
function p2pNextNo(){
  P2P_SEQ++; localStorage.setItem('rhvP2PSeq',P2P_SEQ);
  return 'PR-'+String(P2P_SEQ).padStart(6,'0');
}
function p2pLog(r, action, remarks){
