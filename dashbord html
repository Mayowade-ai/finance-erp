/* ── KPI builders (one per role) ────────────────────────────── */
function _getRoleKPIs(role) {
  const kc = function(label, v, detail, cls, badge) {
    return '<div class="kc ' + (cls||'b') + '">' +
      '<div class="kl">' + label + '</div>' +
      '<div class="kv">' + v + '</div>' +
      (detail ? '<div class="kd">' + detail + '</div>' : '') +
      (badge  ? '<span class="' + badge[0] + '">' + badge[1] + '</span>' : '') +
    '</div>';
  };
  const today  = typeof todayStr === 'function' ? todayStr() : new Date().toISOString().slice(0,10);
  const revArr = typeof gRev === 'function' ? gRev() : Array(12).fill(0);
  const tRev   = revArr.reduce(function(a,b){return a+b;},0);
  const latRev = revArr.filter(function(v){return v>0;}).slice(-1)[0] || 0;
  const f      = typeof fmt === 'function' ? fmt : function(n){return '₦'+n;};
  // ── Revenue / Finance ──
  if (role === 'revenue') {
    var deb     = (DB&&DB.debtors&&DB.debtors.latest)||0;
    var invPend = (typeof INVOICES!=='undefined') ? INVOICES.filter(function(i){return i.status!=='Paid'&&i.status!=='Draft';}).length : 0;
    var rctTod  = (typeof RECEIPTS!=='undefined') ? RECEIPTS.filter(function(r){return r.date===today;}).length : 0;
    return kc('YTD Revenue',         f(tRev),    'Full year',    'g', tRev>0?['kbg','On Track']:null) +
           kc('Latest Month',        f(latRev),  'Most recent',  'b', null) +
           kc('Debtors Outstanding', f(deb),     'Target <₦25M', deb>25e6?'r':'g', deb>25e6?['kbr','⚠ High']:['kbg','✓ OK']) +
           kc('Pending Invoices',    invPend,    'To process',   invPend>0?'a':'g', null) +
           kc('Receipts Today',      rctTod,     'Collected',    'g', null);
  }
  // ── Store ──
  if (role === 'store') {
    var reg    = typeof STOCK_REG!=='undefined' ? STOCK_REG : [];
    var stkVal = reg.reduce(function(s,r){return s+(+r.qty*(+r.unitCost||0)||0);},0);
    var low    = reg.filter(function(r){return +r.qty<=(+r.reorder||0)&&r.item;}).length;
    var srv    = typeof SRV_RECEIPTS!=='undefined' ? SRV_RECEIPTS : [];
    var todRcv = srv.filter(function(r){return r.date===today;}).length;
    var exp90  = reg.filter(function(r){if(!r.expiry)return false;var d=(new Date(r.expiry)-new Date())/864e5;return d>0&&d<90;}).length;
    return kc('Stock Value',       f(stkVal), reg.length+' SKUs',   'b', null) +
           kc('Low Stock Items',   low,       'Below reorder',      low>0?'r':'g', low>0?['kbr','Action']:['kbg','OK']) +
           kc('Expiring ≤ 90 Days',exp90,    'Needs review',       exp90>0?'a':'g', null) +
           kc('Receipts Today',    todRcv,   'SRV posted',         'g', null) +
           kc('Issues Today', (typeof STOCK_OUT!=='undefined'?STOCK_OUT.filter(function(r){return r.date===today;}).length:0), 'Issued', 'a', null);
  }
  // ── Payables ──
  if (role === 'payables') {
    var pay  = (DB&&DB.payables&&DB.payables.summary)||{};
    var invP = (typeof INVOICES!=='undefined') ? INVOICES.filter(function(i){return i.status==='Pending Approval';}).length : 0;
    return kc('Total Outstanding', f(pay.totalOutstanding||0), 'All vendors',   'r', null) +
           kc('Overdue',           f(pay.overdueAmount||0),    'Past due date', (pay.overdueAmount||0)>0?'r':'g', null) +
           kc('Due ≤ 30 Days',    f(pay.dueWithin30||0),      'Upcoming',      'a', null) +
           kc('Active Suppliers',  pay.supplierCount||0,        'Vendors',       'b', null) +
           kc('Invoices Pending',  invP,                        'For approval',  invP>0?'a':'g', null);
  }
  // ── Procurement ──
  if (role === 'procurement') {
    var p2pArr  = typeof P2P!=='undefined' ? P2P : [];
    var open    = p2pArr.filter(function(r){return!['Completed','Rejected','Cancelled'].includes(r.status);}).length;
    var myAct   = p2pArr.filter(function(r){return typeof p2pCanAct==='function'&&p2pCanAct(r)&&!['Completed','Rejected','Cancelled'].includes(r.status);}).length;
    var openPO  = typeof PURCHASE_ORD!=='undefined' ? PURCHASE_ORD.filter(function(p){return!['Received','Cancelled'].includes(p.status);}).length : 0;
    var totVal  = p2pArr.reduce(function(s,r){return s+(+r.amount||0);},0);
    return kc('Open P2P Requests', open,     'Active',              'b', null) +
           kc('Needs My Action',   myAct,    'Awaiting you',        myAct>0?'r':'g', myAct>0?['kbr','Action']:['kbg','Clear']) +
           kc('Open POs',          openPO,   'Not received',        'a', null) +
           kc('Awaiting Payment',  p2pArr.filter(function(r){return r.status==='Awaiting Payment';}).length, 'To process', 'a', null) +
           kc('Total P2P Value',   f(totVal),'All requests',        'gd', null);
  }
  // ── Pharmacy ──
  if (role === 'pharmacy') {
    var reg    = typeof STOCK_REG!=='undefined' ? STOCK_REG : [];
    var drugs  = reg.filter(function(r){return r.category==='Drug'||r.category==='Fluids';});
    var lowDrg = drugs.filter(function(r){return +r.qty<=(+r.reorder||0);}).length;
    var disp   = typeof DISPENSING!=='undefined' ? DISPENSING : [];
    var todD   = disp.filter(function(d){return d.date===today;}).length;
    var myReqs = typeof APPROVALS!=='undefined' ? APPROVALS.filter(function(a){return a.requester==='pharmacy'&&a.status==='PENDING';}).length : 0;
    return kc('Drugs in Stock',   drugs.length,   'Drug SKUs',          'b', null) +
           kc('Low Drug Stock',   lowDrg,          'Below reorder',      lowDrg>0?'r':'g', lowDrg>0?['kbr','Low']:['kbg','OK']) +
           kc('Dispensed Today',  todD,            'Prescriptions',      'g', null) +
           kc('My Pending Reqs',  myReqs,          'Awaiting approval',  myReqs>0?'a':'g', null) +
           kc('Usage Value YTD',  f(disp.reduce(function(s,d){return s+(+d.value||0);},0)), 'Total dispensed', 'a', null);
  }
  // ── Lab / Radiology / Ophthal / CSSD ──
  if (['lab','radiology','ophthal','cssd'].includes(role)) {
    var myReqs = typeof REQS!=='undefined' ? REQS.filter(function(r){return r.requester===role;}) : [];
    var openR  = myReqs.filter(function(r){return!['Completed','Rejected'].includes(r.status);}).length;
    var doneR  = myReqs.filter(function(r){return r.status==='Completed';}).length;
    var qryR   = myReqs.filter(function(r){return r.status==='Queried';}).length;
    var catMap = {lab:'Lab Materials',radiology:'X-Ray Materials',ophthal:'Consumables',cssd:'CSSD Pack'};
    var myStk  = typeof STOCK_REG!=='undefined' ? STOCK_REG.filter(function(r){return r.category===catMap[role];}) : [];
    var myLow  = myStk.filter(function(r){return +r.qty<=(+r.reorder||0);}).length;
    return kc('My Open Requests', openR,       'Active',           openR>0?'a':'g', null) +
           kc('Queried / Action', qryR,        'Needs response',   qryR>0?'r':'g', qryR>0?['kbr','Respond']:null) +
           kc('Completed',        doneR,       'This period',      'g', null) +
           kc('My Stock Items',   myStk.length,'In register',      'b', null) +
           kc('Low Stock',        myLow,       'Needs reorder',    myLow>0?'r':'g', myLow>0?['kbr','Action']:['kbg','OK']);
  }
  return kc('YTD Revenue', f(tRev), 'Full year', 'g', null) + kc('Latest Month', f(latRev), '', 'b', null);
