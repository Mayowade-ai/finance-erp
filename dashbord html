function submitPO(){
  const vendor=val('f-poVendor'); const terms=val('f-poTerms');
  const lines=lineValid();
  if(!vendor){alert('Vendor is required.');return false;}
  if(!lines.length){alert('Add at least one line item (with item name and qty).');return false;}
  if(!terms){alert('Payment Terms is mandatory.');return false;}
  const total=lines.reduce((s,r)=>s+(+r.qty)*(+r.price||0),0);
  const qtyTot=lines.reduce((s,r)=>s+(+r.qty),0);
  const itemSummary=lines.length===1?lines[0].item:lines[0].item+' +'+(lines.length-1)+' more';
  const poNo=val('f-poNo');
  const attachment=saveAttachment(poNo);
  const rec={ poNo, date:val('f-poDate'), vendor, item:itemSummary, category:val('f-poCat'),
    qty:qtyTot, unitPrice:lines.length===1?(+lines[0].price||0):0, total,
    lines:lines.map(r=>({item:r.item,desc:r.desc,qty:+r.qty,price:+r.price||0,total:(+r.qty)*(+r.price||0)})),
    expectedDate:val('f-poExp')||addDays(todayStr(),3),
    paymentTerms:terms, requestedBy:val('f-poBy'), clause:val('f-poClause')||PO_CLAUSE,
    notes:val('f-poNotes'), attachment, status:'Draft', ts:new Date().toISOString() };
  PURCHASE_ORD.unshift(rec); saveLS('rhvPO',PURCHASE_ORD);
  syncToSheet('Purchase Orders', rec);
  addAuditEntry('Supply Chain','PO Created', rec.poNo, '—', vendor+' '+fmt(rec.total));
  addNotif('Procurement','🛒','PO '+rec.poNo+' created','Vendor '+vendor+' — '+fmt(rec.total)+' · '+lines.length+' line(s)','medium');
  notifyEvent('PO Created','Procurement & Dept', rec.poNo+' for '+vendor, deptEmail('Procurement'));
  routeApproval('PO', rec.poNo, rec.total, rec.requestedBy, vendor+' — '+itemSummary);
  UPLOAD_FILE=null;
  rSupplyChain();
  return true;
}
