  const rows=[];
  RECEIPTS.forEach(r=>rows.push({date:r.date,desc:'Receipt '+r.rcptNo+' '+r.customer,amount:+r.amount,matched:!!r._m}));
  (DB?.payables?.rows||[]).forEach(p=>rows.push({date:p.date||'',desc:'Payable '+(p.supplier||''),amount:-(+p.amount||0),matched:false}));
  return rows;
}
