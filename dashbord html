    const baseURL=getURL().split('?')[0];
    const url=`${baseURL}?token=${tok}&action=all`;
    sT('connSt','Sending: '+url.slice(0,80)+'…');
    const r=await fetch(url,{redirect:'follow'});
    const t=await r.text();
    const j=JSON.parse(t.match(/\{[\s\S]*\}/)?.[0]||t);
    if(j.status && !j.revenue){
      sT('connSt','⚠️ API is live but token not accepted — copy only the /exec URL with no extra characters');
      return;
    }
    if(j.error){sT('connSt','❌ Error: '+j.error+(j.hint?' — '+j.hint:''));return;}
    if(j.meta||j.revenue){
      localStorage.setItem('rhvScriptURL', baseURL);
      sT('connSt','✅ Connected! Workbook: '+(j.meta?.workbook||'RHV Finance')+' — refreshing data…');
      refAll();
    }else{
      sT('connSt','⚠️ Unexpected response — check Apps Script is deployed correctly');
