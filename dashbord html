function submitGRN(){
  const poNo=val('f-grnPO'); const po=PURCHASE_ORD.find(p=>p.poNo===poNo);
  if(!po){alert('Select a PO.');return false;}
  const recvQty=+val('f-grnQty'); if(!recvQty){alert('Enter quantity received.');return false;}
  const match = recvQty===po.qty?'Full':(recvQty<po.qty?'Short':'Over');
  const rec={ grnNo:val('f-grnNo'), date:val('f-grnDate'), poRef:poNo, vendor:po.vendor, item:po.item,
    category:po.category, poQty:po.qty, recvQty, unitCost:po.unitPrice, batch:val('f-grnBatch'),
    expiry:val('f-grnExp'), condition:val('f-grnCond'), match, receivedBy:val('f-grnBy'), ts:new Date().toISOString() };
  GRNS.unshift(rec); saveLS('rhvGRN',GRNS); syncToSheet('Goods Received', rec);
  // Mark PO received, auto-receive into stock (only if good condition)
  po.status='Received'; saveLS('rhvPO',PURCHASE_ORD); syncToSheet('Purchase Orders',po);
  if(val('f-grnCond')!=='Rejected'){
    let s=STOCK_REG.find(x=>x.item.toLowerCase()===po.item.toLowerCase()&&x.category===po.category);
    if(s){s.qty=+s.qty+recvQty; s.unitCost=po.unitPrice||s.unitCost; s.lastReceived=rec.date; if(rec.expiry)s.expiry=rec.expiry; if(rec.batch)s.batch=rec.batch;}
    else STOCK_REG.unshift({item:po.item,category:po.category,qty:recvQty,unit:'unit',unitCost:po.unitPrice,reorder:0,batch:rec.batch,expiry:rec.expiry,lastReceived:rec.date});
    saveLS('rhvStockReg',STOCK_REG);
    // SRV record
    const srv={srvNo:genID('SRV'),date:rec.date,poRef:poNo,item:po.item,category:po.category,qty:recvQty,unit:'unit',unitCost:po.unitPrice,vendor:po.vendor,batch:rec.batch,expiry:rec.expiry,receivedBy:rec.receivedBy,ts:new Date().toISOString()};
    SRV_RECEIPTS.unshift(srv); saveLS('rhvSRV',SRV_RECEIPTS); syncToSheet('SRV Receipts',srv);
  }
  // GL: Dr Inventory, Cr Accounts Payable
  const val_=recvQty*(po.unitPrice||0);
  if(val_>0) postJournal('GRN', rec.grnNo, rec.date, 'Goods received '+po.item+' from '+po.vendor,
    [{acct:catInvAcct(po.category),dr:val_},{acct:ACCT.AP_TRADE,cr:val_}]);
  addAuditEntry && addAuditEntry('Supply Chain','GRN Created', rec.grnNo, 'PO '+poNo, match+' match ×'+recvQty);
  addNotif && addNotif('Stores','📥 GRN '+rec.grnNo+' — '+po.item+' received ('+match+')', match==='Full'?'info':'warn');
  rGRN(); return true;
}
