function adeSystemPrompt() {
  const role      = CU ? (ROLES[CU]?.lbl || CU) : 'Guest';
  const roleLower = (CU||'').toLowerCase();
  // Pull live ERP data the current user can see
  const rev = typeof gRev === 'function' ? gRev() : [];
  const exp = typeof gExp === 'function' ? gExp() : [];
  const tRev = rev.reduce((a,b)=>a+b,0);
  const tExp = exp.reduce((a,b)=>a+b,0);
  const latRev = rev.filter(v=>v>0).slice(-1)[0] || 0;
  const deb = DB?.debtors?.latest || 0;
  const pendAppr = (typeof APPROVALS!=='undefined') ? APPROVALS.filter(a=>a.status==='PENDING').length : 0;
  const p2pOpen  = (typeof P2P!=='undefined')       ? P2P.filter(r=>!['Completed','Rejected','Cancelled'].includes(r.status)).length : 0;
  const lowStock = (typeof STOCK_REG!=='undefined')  ? STOCK_REG.filter(r=>+r.qty<=(+r.reorder||0)&&r.item).length : 0;
  // Restrict data per role
  const canSeeFinance  = ['admin','revenue','payables','coo','ceo'].includes(roleLower);
  const canSeeStore    = ['admin','store','procurement','coo','ceo'].includes(roleLower);
  const canSeeProc     = ['admin','procurement','payables','coo','ceo'].includes(roleLower);
  const canSeePharm    = ['admin','pharmacy','coo','ceo'].includes(roleLower);
  const canSeeKitchen  = ['admin','store','coo','ceo'].includes(roleLower);
  const canSeeExec     = ['admin','coo','ceo'].includes(roleLower);
  let dataContext = `\n\n=== LIVE ERP DATA (accessible to ${role}) ===\n`;
  dataContext += `Hospital: Redeemers Health Village (RHV), Lagos, Nigeria\n`;
  dataContext += `Current User Role: ${role}\n`;
  dataContext += `Currency: Nigerian Naira (₦). Format millions as ₦Xm or ₦X,XXX,XXX.\n`;
  if (canSeeFinance) {
    const MO = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const nonZeroMonths = rev.filter(v=>v>0).length;
    dataContext += `\n--- FINANCE DATA ---\n`;
    dataContext += `YTD Revenue: ₦${(tRev/1e6).toFixed(1)}M (${nonZeroMonths} months)\n`;
    dataContext += `YTD Expenditure: ₦${(tExp/1e6).toFixed(1)}M\n`;
    dataContext += `Net Surplus/(Deficit): ₦${((tRev-tExp)/1e6).toFixed(1)}M\n`;
    dataContext += `Latest Month Revenue: ₦${(latRev/1e6).toFixed(1)}M\n`;
    dataContext += `Monthly Target (2025): ₦120M | (2026): ₦180M\n`;
    dataContext += `Total Debtors Outstanding: ₦${(deb/1e6).toFixed(1)}M (target <₦25M)\n`;
    dataContext += `Debtor/Revenue Ratio: ${latRev>0?((deb/latRev)*100).toFixed(1):0}% (target <20%)\n`;
    const streams = DB?.streams?.slice(0,5)||[];
    if(streams.length) dataContext += `Top Revenue Streams: ${streams.map(s=>`${s.name} (₦${(s.ytd/1e6).toFixed(1)}M)`).join(', ')}\n`;
    dataContext += `Pending Approvals: ${pendAppr}\n`;
    const invoices = typeof INVOICES!=='undefined' ? INVOICES : [];
    dataContext += `Outstanding Invoices: ${invoices.filter(i=>i.status!=='Paid').length}\n`;
    const receipts = typeof RECEIPTS!=='undefined' ? RECEIPTS : [];
    dataContext += `Receipts Issued: ${receipts.length}\n`;
  }
  if (canSeeStore) {
    const reg = typeof STOCK_REG!=='undefined' ? STOCK_REG : [];
    const srv = typeof SRV_RECEIPTS!=='undefined' ? SRV_RECEIPTS : [];
    const stockVal = reg.reduce((s,r)=>s+(+r.qty*(+r.unitCost||0)),0);
    const expired  = typeof EXPIRED!=='undefined' ? EXPIRED.reduce((s,r)=>s+(+r.value||0),0) : 0;
    dataContext += `\n--- STORE / INVENTORY DATA ---\n`;
    dataContext += `Total Stock Items (SKUs): ${reg.length}\n`;
    dataContext += `Total Stock Value: ₦${(stockVal/1e6).toFixed(2)}M\n`;
    dataContext += `Low Stock Items: ${lowStock}\n`;
    dataContext += `Expired/Written-Off Value: ₦${(expired/1e3).toFixed(0)}K\n`;
    dataContext += `Store Receipts (SRV): ${srv.length}\n`;
    const topLow = reg.filter(r=>+r.qty<=(+r.reorder||0)&&r.item).slice(0,5);
    if(topLow.length) dataContext += `Low Stock Items: ${topLow.map(r=>`${r.item} (${r.qty}/${r.reorder})`).join(', ')}\n`;
  }
  if (canSeeProc) {
    const p2pArr = typeof P2P!=='undefined' ? P2P : [];
    const poArr  = typeof PURCHASE_ORD!=='undefined' ? PURCHASE_ORD : [];
    const p2pVal = p2pArr.reduce((s,r)=>s+(+r.amount||0),0);
    dataContext += `\n--- PROCUREMENT / P2P DATA ---\n`;
    dataContext += `Total P2P Requests: ${p2pArr.length}\n`;
    dataContext += `Open P2P Requests: ${p2pOpen}\n`;
    dataContext += `Total P2P Value: ₦${(p2pVal/1e6).toFixed(1)}M\n`;
    dataContext += `Pending Gate 1 Approval: ${p2pArr.filter(r=>r.status==='Submitted'||r.status==='Pending Management Approval').length}\n`;
    dataContext += `Awaiting Payment: ${p2pArr.filter(r=>r.status==='Awaiting Payment').length}\n`;
    dataContext += `Completed: ${p2pArr.filter(r=>r.status==='Completed').length}\n`;
    dataContext += `Purchase Orders: ${poArr.length} (Open: ${poArr.filter(p=>!['Received','Cancelled'].includes(p.status)).length})\n`;
    dataContext += `Active Vendors: ${new Set(poArr.map(p=>p.vendor)).size}\n`;
  }
  if (canSeePharm) {
    const disp  = typeof DISPENSING!=='undefined' ? DISPENSING : [];
    const drugs = typeof STOCK_REG!=='undefined'  ? STOCK_REG.filter(r=>r.category==='Drug'||r.category==='Fluids') : [];
    const lowDr = drugs.filter(r=>+r.qty<=(+r.reorder||0)).length;
    dataContext += `\n--- PHARMACY DATA ---\n`;
    dataContext += `Total Drug SKUs: ${drugs.length}\n`;
    dataContext += `Low Drug Stock Items: ${lowDr}\n`;
    dataContext += `Total Dispensing Records: ${disp.length}\n`;
    dataContext += `Total Dispensing Value: ₦${(disp.reduce((s,d)=>s+(+d.value||0),0)/1e6).toFixed(2)}M\n`;
  }
  if (canSeeKitchen) {
    const kitO = typeof KIT_ORDERS!=='undefined' ? KIT_ORDERS : [];
    const kitS = typeof KIT_STORE!=='undefined'  ? KIT_STORE  : [];
    const kitM = typeof KIT_MENU!=='undefined'   ? KIT_MENU   : [];
    const kitStVal = kitS.reduce((s,r)=>s+(+r.qty*(+r.cost||0)),0);
    dataContext += `\n--- KITCHEN DATA ---\n`;
    dataContext += `Total Meal Orders: ${kitO.length}\n`;
    dataContext += `Menu Items: ${kitM.length}\n`;
    dataContext += `Kitchen Store Value: ₦${(kitStVal/1e3).toFixed(0)}K\n`;
    dataContext += `Low Kitchen Ingredients: ${kitS.filter(r=>+r.qty<=(+r.reorder||0)).length}\n`;
  }
  // Knowledge base articles
  const kbText = ADE_KB.map(k=>`[${k.title}]: ${k.content}`).join('\n\n');
  const userKB  = (ADE_CFG.kbDocs||[]).join('\n\n');
  return `You are ADE (AI-Driven ERP Assistant), the intelligent digital assistant for Redeemers Health Village (RHV) Hospital ERP Dashboard.
## Your Identity
- Name: ADE (AI-Driven ERP Assistant)
- Version: ${ADE_VERSION}
- Hospital: Redeemers Health Village (RHV), Lagos, Nigeria
- You operate strictly WITHIN the ERP context
## Your Capabilities
You can help users:
1. **Navigate the ERP** — provide step-by-step guidance for any module or workflow
2. **Analyze ERP data** — revenue, expenses, stock, procurement, pharmacy, kitchen
3. **Generate insights** — variances, trends, anomalies, KPI interpretations
4. **Draft documents** — emails, memos, approval requests, vendor communications
5. **Answer operational questions** — workflows, KPI definitions, SOPs, policies
6. **Provide decision support** — recommendations based on ERP data
## Role-Based Access
Current user role: **${role}**
You must ONLY discuss data and modules the ${role} role can access.
Never reveal financial data to Kitchen/Store users unless they have finance access.
Never reveal HR confidential data to non-admin users.
## Response Style
- Be concise and professional — this is a hospital ERP context
- Use ₦ for Nigerian Naira amounts
- Format numbers in millions as ₦Xm (e.g., ₦37.3M)
- Use bullet points and tables where helpful
- Highlight urgent/critical items with ⚠️ or 🔴
- Provide actionable recommendations
- If asked to navigate somewhere in the ERP, say which module and how to get there
- Keep responses focused and relevant to the ERP context
- When in doubt about data accuracy, say so
## ERP Knowledge Base
${kbText}
${userKB ? '## Additional Knowledge Base\n' + userKB : ''}
${dataContext}
## Current Date & Time
${new Date().toLocaleString('en-GB', {weekday:'long',day:'2-digit',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'})}
## Important Rules
1. Never fabricate ERP data — use only the data provided in the context above
2. If asked about data you cannot access, politely explain the role restriction
3. Always stay within ERP/hospital operations context
4. Log all interactions (they are automatically audited)
5. If a user asks about something not in your knowledge base, say you are not sure and suggest contacting IT or system admin`;
}
