function vendorAgg(){
  const map={};
  PURCHASE_ORD.forEach(p=>{const v=p.vendor||'Unknown';if(!map[v])map[v]={vendor:v,purchases:0,paid:0,buckets:[0,0,0,0]};
    map[v].purchases+=p.total||0;
    if(p.status==='Completed'||p.status==='Received')map[v].paid+=p.total||0;
    else{const days=Math.floor((Date.now()-new Date(p.date||Date.now()))/864e5);const b=days<=30?0:days<=60?1:days<=90?2:3;map[v].buckets[b]+=p.total||0;}
  });
  return Object.values(map);
}
