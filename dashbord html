/* ── Alert / attention section ──────────────────────────────── */
function _getRoleAlerts(role) {
  var today = typeof todayStr === 'function' ? todayStr() : new Date().toISOString().slice(0,10);
  var items = [];
  var f     = typeof fmt === 'function' ? fmt : function(n){return '₦'+n;};
  // Low stock (store + pharmacy)
  if (role === 'store' || role === 'pharmacy') {
    var reg   = typeof STOCK_REG !== 'undefined' ? STOCK_REG : [];
    var drugs = role === 'pharmacy' ? ['Drug','Fluids'] : null;
    var low   = reg.filter(function(r) {
      return (!drugs || drugs.includes(r.category)) && +r.qty <= (+r.reorder||0) && r.item;
    }).slice(0,5);
    low.forEach(function(r) { items.push({
      icon:'🔴', type:'danger',
      title:'Low Stock: ' + escapeHtml(r.item),
      body:'Only ' + r.qty + ' ' + (r.unit||'units') + ' remaining. Reorder at ' + r.reorder + '.',
      go: "nav('store',document.querySelector('[data-pg=store]'));storeTab('reg',null)", lbl:'View Register'
    }); });
    var exp90 = reg.filter(function(r){
      if(!r.expiry||(!drugs||drugs.includes(r.category))) return false;
      var d=(new Date(r.expiry)-new Date())/864e5; return d>0&&d<90;
    }).slice(0,3);
    exp90.forEach(function(r){
      var days=Math.round((new Date(r.expiry)-new Date())/864e5);
      items.push({icon:'🟡',type:'warn',
        title:'Expiring: '+escapeHtml(r.item),
        body:'Expires in '+days+' days ('+r.expiry+'). Qty: '+r.qty+'.',
        go:"nav('store',document.querySelector('[data-pg=store]'));storeTab('exp',null)",lbl:'Expiry List'});
    });
  }
  // Procurement: P2P needs action
  if (role === 'procurement') {
    var myAct = (typeof P2P!=='undefined'&&typeof p2pCanAct==='function')
      ? P2P.filter(function(r){return p2pCanAct(r)&&!['Completed','Rejected','Cancelled'].includes(r.status);})
      : [];
    myAct.slice(0,5).forEach(function(r){ items.push({
      icon:'🛒', type:'info',
      title: r.prNo + ' — ' + escapeHtml(r.item),
      body: escapeHtml(r.dept) + ' · Status: ' + r.status + ' · ' + f(r.amount),
      go: "nav('p2p',document.querySelector('[data-pg=p2p]'));if(typeof openP2PDetail==='function')openP2PDetail('"+r.prNo+"')",
      lbl: 'Open Request'
    }); });
  }
  // Dept roles: queried requests
  if (['lab','radiology','ophthal','cssd','pharmacy'].includes(role)) {
    var queried = typeof REQS!=='undefined'
      ? REQS.filter(function(r){return r.requester===role&&r.status==='Queried';})
      : [];
    queried.slice(0,3).forEach(function(r){ items.push({
      icon:'🟠', type:'warn',
      title: 'Query: ' + r.reqNo + ' — ' + escapeHtml(r.item),
      body: 'Management query: ' + escapeHtml(r.queryNote||'See request details.'),
      go: "nav('reqtrack',document.querySelector('[data-pg=reqtrack]'))", lbl: 'View Request'
    }); });
  }
  // Revenue: overdue invoices
  if (role === 'revenue') {
    var ovdInv = typeof INVOICES!=='undefined'
      ? INVOICES.filter(function(i){return i.status!=='Paid'&&i.dueDate&&i.dueDate<today;})
      : [];
    ovdInv.slice(0,4).forEach(function(i){ items.push({
      icon:'🔴', type:'danger',
      title: 'Overdue Invoice: ' + i.invNo,
      body: escapeHtml(i.customer) + ' · ' + f(i.total) + ' · Due: ' + i.dueDate,
      go: "nav('invoicing',document.querySelector('[data-pg=invoicing]'))", lbl:'View Invoices'
    }); });
  }
  // Payables: overdue
  if (role === 'payables') {
    var ovdPay = (DB&&DB.payables&&DB.payables.rows) ? DB.payables.rows.filter(function(r){return r.overdue;}) : [];
    ovdPay.slice(0,4).forEach(function(r){ items.push({
      icon:'🔴', type:'danger',
      title: 'Overdue: ' + escapeHtml(r.supplier),
      body: f(r.amount) + ' · Due: ' + (r.dueDate||'—'),
      go: "nav('payables',document.querySelector('[data-pg=payables]'))", lbl:'View Payables'
    }); });
  }
  if (!items.length) return (
    '<div class="cbox" style="text-align:center;padding:24px;color:var(--muted)">' +
      '<div style="font-size:32px">&#10003;</div>' +
      '<div style="font-size:13px;font-weight:600;margin:8px 0">All clear</div>' +
      '<div style="font-size:11px">No pending items need your attention right now.</div>' +
    '</div>'
  );
  var styles = {
    danger:'background:#FEECEC;border-color:#F1948A',
    warn:  'background:#FFF9E6;border-color:#F4D03F',
    info:  'background:#EBF5FB;border-color:#85C1E9'
  };
  return '<div class="tbox"><h4 style="margin-bottom:10px">&#9888; Needs Your Attention (' + items.length + ')</h4>' +
    items.map(function(it) { return (
      '<div style="display:flex;align-items:flex-start;gap:10px;padding:9px 11px;border-radius:8px;' +
        'margin-bottom:6px;border:1px solid;' + (styles[it.type]||styles.info) + '">' +
        '<span style="font-size:18px;flex-shrink:0">' + it.icon + '</span>' +
        '<div style="flex:1;min-width:0">' +
          '<div style="font-size:12px;font-weight:700">' + it.title + '</div>' +
          '<div style="font-size:11px;color:var(--text);margin-top:2px">' + it.body + '</div>' +
        '</div>' +
        '<button class="ebtn" style="flex-shrink:0;padding:3px 9px" onclick="' + it.go + '">' + it.lbl + '</button>' +
      '</div>'
    ); }).join('') +
  '</div>';
}
