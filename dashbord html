function _parseCashCSV() {
  var text  = (document.getElementById('cash-paste') && document.getElementById('cash-paste').value) || '';
  var lines = text.split(/\r?\n/).map(function(l){return l.trim();}).filter(Boolean);
  var rows  = [];
  var postedBy = (typeof ROLES!=='undefined'&&ROLES[CU]) ? ROLES[CU].lbl : 'CSV Import';
  lines.forEach(function(ln, i) {
    var c = ln.split(',').map(function(x){return x.trim().replace(/^"|"$/g,'');});
    if (i === 0 && /date|dept/i.test(ln)) return; // skip header row
    var amt = +(c[2]||'').replace(/[^\d.]/g,'');
    if (!c[0] || !amt) return;
    rows.push({
      id:          Date.now() + i,
      date:        c[0],
      dept:        c[1] || 'General',
      amount:      amt,
      description: c[3] || (c[1]||'General') + ' collection',
      method:      c[4] || 'Cash',
      type:        (c[5]||'receipt').trim().toLowerCase().indexOf('pay') >= 0 ? 'payment' : 'receipt',
      reference:   c[6] || '',
      postedBy:    postedBy,
      ts:          new Date().toISOString()
    });
  });
  return rows;
}
