function assetFileLoad(inp){
  const f=inp.files[0]; if(!f)return;
  const r=new FileReader();
  r.onload=()=>{ document.getElementById('f-asPaste').value=r.result; assetParse(r.result,true); };
  r.readAsText(f);
}
function assetSplit(line){
  // tab first; else comma (respecting simple quotes)
  if(line.indexOf('\t')>-1) return line.split('\t');
  const out=[]; let cur='',q=false;
  for(const ch of line){ if(ch==='"'){q=!q;} else if(ch===','&&!q){out.push(cur);cur='';} else cur+=ch; }
  out.push(cur); return out;
}
function assetParse(text,preview){
  const lines=text.split(/\r?\n/).map(l=>l.trim()).filter(Boolean);
  const rows=[];
  lines.forEach((ln,i)=>{
    const c=assetSplit(ln).map(x=>x.trim());
    if(i===0 && /asset|category|cost/i.test(ln) && isNaN(+(c[5]||''))) return; // skip header
    if(!c[0]) return;
    rows.push({asset:c[0],category:c[1]||'Other',purchaseDate:c[2]||'',dateReceived:c[3]||'',
      vendor:c[4]||'',cost:+(String(c[5]||'').replace(/[^\d.]/g,''))||0,department:c[6]||'',status:c[7]||'Active'});
  });
  if(preview){ const p=document.getElementById('as-preview'); if(p)p.textContent='✓ '+rows.length+' assets detected — total value '+fmt(rows.reduce((s,r)=>s+r.cost,0)); }
  return rows;
}
function submitAssetUpload(){
